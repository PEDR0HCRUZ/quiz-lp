    "var_bd3fb7e75af9": {
      "type": "variant",
      "label": "remix-psi-quiz",
      "parentId": "node_paste_4a007abfe51f",
      "themeId": null,
      "rect": {
        "x": 1540,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Lora:ital,wght@0,400;0,500;1,400&family=Archivo:wght@400;500;600&display=swap');\n\n:root {\n  --gold: #C8A24B;\n  --charcoal: #22201C;\n  --bone: #EFE8DC;\n  --acacia: #5C6B4A;\n  --ochre: #B05A2E;\n}\n\n.font-display { font-family: 'Fraunces', serif; }\n.font-body { font-family: 'Lora', serif; }\n.font-caps { font-family: 'Archivo', sans-serif; }\n\n.kicker {\n  font-family: 'Archivo', sans-serif;\n  text-transform: uppercase;\n  letter-spacing: 0.22em;\n  font-size: 11px;\n}\n\n.kicker-lg {\n  font-family: 'Archivo', sans-serif;\n  text-transform: uppercase;\n  letter-spacing: 0.22em;\n  font-size: 12px;\n}\n\n.body-col {\n  font-family: 'Lora', serif;\n  font-size: 18.5px;\n  line-height: 1.7;\n}\n\n.reveal { opacity: 1; }\n\n::selection {\n  background: var(--gold);\n  color: var(--charcoal);\n}\n\nhtml { scroll-behavior: smooth; }\n\n.gold-rule {\n  height: 1px;\n  background: var(--gold);\n}\n\n.dropcap::first-letter {\n  font-family: 'Fraunces', serif;\n  font-weight: 400;\n  font-size: 6.2rem;\n  line-height: 0.78;\n  float: left;\n  color: var(--ochre);\n  padding: 0.35rem 0.2rem 0 0;\n}\n\n.link-underline {\n  background-image: linear-gradient(var(--gold), var(--gold));\n  background-size: 100% 1px;\n  background-repeat: no-repeat;\n  background-position: 0 100%;\n  padding-bottom: 2px;\n}\n\n/* Custom styles for animations to work as per guidelines */\n.gsap-reveal {\n  /* No opacity: 0 here to follow GSAP constraints */\n}\n</style>\n<div class=\"font-body\" data-kid=\"1\" data-name=\"page layout container\" style=\"background:var(--bone);color:var(--charcoal);overflow-x:clip;\">\n    \n    <nav class=\"fixed top-0 left-0 right-0 z-50\" data-kid=\"1-1\" data-name=\"main navigation header\" style=\"mix-blend-mode:difference;\">\n        <div class=\"flex items-center justify-between px-6 md:px-12 py-5\" data-kid=\"1-1-1\" data-name=\"navigation flex container\">\n            <a class=\"font-display text-xl tracking-wide\" data-kid=\"1-1-1-1\" data-name=\"brand logo name\" href=\"#\" style=\"color:#EFE8DC;\">\n                Descoberta\n            </a>\n            <div class=\"hidden md:flex items-center gap-8 kicker\" data-kid=\"1-1-1-2\" data-name=\"navigation menu links\" style=\"color:#EFE8DC;\">\n                <a class=\"hover:opacity-60\" data-kid=\"1-1-1-2-1\" data-name=\"essay link\" href=\"#essay\">\n                    O Ensaio\n                </a>\n                <a class=\"hover:opacity-60\" data-kid=\"1-1-1-2-2\" data-name=\"fases link\" href=\"#seasons\">\n                    Fases\n                </a>\n                <a class=\"hover:opacity-60\" data-kid=\"1-1-1-2-3\" data-name=\"espacos link\" href=\"#suites\">\n                    Espaços\n                </a>\n                <a class=\"hover:opacity-60\" data-kid=\"1-1-1-2-4\" data-name=\"contato link\" href=\"#enquire\">\n                    Contato\n                </a>\n            </div>\n        </div>\n    </nav>\n    \n    <header class=\"relative h-screen w-full overflow-hidden\" data-kid=\"1-2\" data-name=\"hero section\" id=\"hero\" style=\"background:var(--charcoal);\">\n        <div class=\"absolute inset-0 -z-0\" data-kid=\"1-2-1\" data-name=\"hero image wrapper\" id=\"hero-img-wrap\">\n            <img alt=\"Onde a clareza encontra o seu novo caminho\" class=\"w-full h-[120%] object-cover\" data-kid=\"1-2-1-1\" data-name=\"hero background image\" decoding=\"async\" id=\"hero-img\" loading=\"lazy\" src=\"https://images.pexels.com/photos/2260959/pexels-photo-2260959.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80\" style=\"filter:brightness(0.62) saturate(1.05);\">\n        </div>\n        <div class=\"absolute inset-0\" data-kid=\"1-2-2\" data-name=\"hero gradient overlay\" style=\"background:linear-gradient(115deg,rgba(34,32,28,0.78) 0%,rgba(34,32,28,0.35) 45%,rgba(34,32,28,0.15) 100%);\">\n        </div>\n        <div class=\"absolute inset-0 pointer-events-none\" data-kid=\"1-2-3\" data-name=\"hero top gradient fade\" style=\"background:linear-gradient(to bottom, rgba(34,32,28,0.5) 0%, transparent 15%);\">\n        </div>\n        <div class=\"relative z-10 h-full px-6 md:px-16 lg:px-24 flex flex-col justify-center max-w-[1100px]\" data-kid=\"1-2-4\" data-name=\"hero text content container\" id=\"hero-text\">\n            <p class=\"kicker-lg mb-7\" data-kid=\"1-2-4-1\" data-name=\"hero kicker text\" style=\"color:var(--gold);\">\n                Uma Jornada de Autoconhecimento · Perfil Psicológico\n            </p>\n            <h1 class=\"font-display font-light leading-[0.92] tracking-[-0.01em]\" data-kid=\"1-2-4-2\" data-name=\"hero headline\" style=\"color:var(--bone);font-size:clamp(3rem,8vw,7.5rem);\">\n                Onde a clareza\n                <br data-kid=\"1-2-4-2-1\" data-name=\"headline line break\">\n                encontra o seu\n                <br data-kid=\"1-2-4-2-2\" data-name=\"headline line break\">\n                <span class=\"italic\" data-kid=\"1-2-4-2-3\" data-name=\"italic headline emphasis\" style=\"color:var(--gold);\">\n                    novo caminho\n                </span>\n            </h1>\n            <div class=\"gold-rule w-32 mt-10 mb-7\" data-kid=\"1-2-4-3\" data-name=\"gold rule horizontal line\">\n            </div>\n            <p class=\"kicker max-w-md\" data-kid=\"1-2-4-4\" data-name=\"hero description text\" style=\"color:var(--bone);opacity:0.85;line-height:2;\">\n                Doze dimensões do ser · Análise profunda · Um portal construído para quem busca respostas\n            </p>\n        </div>\n        <div class=\"absolute bottom-8 right-8 md:right-16 z-10 flex items-center gap-3\" data-kid=\"1-2-5\" data-name=\"scroll indicator container\">\n            <span class=\"kicker\" data-kid=\"1-2-5-1\" data-name=\"scroll text\" style=\"color:var(--bone);\">\n                Scroll\n            </span>\n            <span class=\"block w-10 gold-rule\" data-kid=\"1-2-5-2\" data-name=\"scroll line indicator\">\n            </span>\n        </div>\n    </header>\n    \n    <section class=\"px-6 md:px-16 lg:px-24 py-24 md:py-36\" data-kid=\"1-3\" data-name=\"essay section\" id=\"essay\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-14 lg:gap-x-12\" data-kid=\"1-3-1\" data-name=\"essay grid container\">\n            <div class=\"lg:col-span-2 lg:col-start-1\" data-kid=\"1-3-1-1\" data-name=\"essay sidebar column\">\n                <p class=\"kicker reveal\" data-kid=\"1-3-1-1-1\" data-name=\"essay chapter kicker\" style=\"color:var(--gold);\">\n                    Capítulo Um\n                </p>\n                <p class=\"font-display italic text-2xl mt-3 reveal\" data-kid=\"1-3-1-1-2\" data-name=\"essay chapter title\" style=\"color:var(--acacia);\">\n                    A Observação\n                </p>\n            </div>\n            <div class=\"lg:col-span-5 lg:col-start-3\" data-kid=\"1-3-1-2\" data-name=\"essay text column\">\n                <p class=\"body-col dropcap reveal\" data-kid=\"1-3-1-2-1\" data-name=\"dropcap body paragraph\">\n                    Antes que o ruído do mundo se sobreponha à sua voz interior, o silêncio revela a verdade. No deserto da mente, as sombras se alongam e os padrões começam a emergir. Não buscamos pressa aqui. Ouvimos — a intuição, o eco dos traumas, o lento movimento da consciência em direção à luz.\n                </p>\n                <p class=\"body-col mt-6 reveal\" data-kid=\"1-3-1-2-2\" data-name=\"essay paragraph\">\n                    A Jornada Interna é um espaço de clareza absoluta, desenhado para quem está pronto para se encarar. Não há distrações, apenas a paciência deliberada que a autoanálise exige — e as descobertas extraordinárias que ela recompensa.\n                </p>\n                <p class=\"body-col mt-6 reveal\" data-kid=\"1-3-1-2-3\" data-name=\"essay paragraph\">\n                    Aqui, o dia é organizado pela percepção, não pelo cronômetro. O primeiro passo é o mais profundo, preparando o terreno para que sua essência se revele sob uma nova perspectiva.\n                </p>\n            </div>\n            <div class=\"lg:col-span-3 lg:col-start-9 self-start\" data-kid=\"1-3-1-3\" data-name=\"essay sidebar note\">\n                <p class=\"kicker reveal\" data-kid=\"1-3-1-3-1\" data-name=\"sidebar kicker\" style=\"color:var(--ochre);\">\n                    Uma Nota Lateral\n                </p>\n                <p class=\"font-body italic mt-3 reveal\" data-kid=\"1-3-1-3-2\" data-name=\"sidebar note body\" style=\"font-size:15px;line-height:1.7;color:var(--acacia);\">\n                    Nossos analistas são especialistas em comportamento humano, focados na decodificação de arquétipos. Eles leem o seu silêncio como você lê um mapa.\n                </p>\n            </div>\n        </div>\n    </section>\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-10\" data-kid=\"1-4\" data-name=\"portrait section\">\n        <div class=\"lg:col-span-4 lg:col-start-2 px-6 lg:px-0 order-2 lg:order-1\" data-kid=\"1-4-1\" data-name=\"portrait text column\">\n            <p class=\"kicker reveal\" data-kid=\"1-4-1-1\" data-name=\"portrait kicker\" style=\"color:var(--gold);\">\n                Nota de Campo · 03:42\n            </p>\n            <p class=\"body-col mt-4 reveal\" data-kid=\"1-4-1-2\" data-name=\"portrait paragraph\">\n                Uma clareza súbita surgiu no centro do caos mental. Paramos o pensamento e apenas observamos por quase uma hora. A recompensa não foi a solução imediata — foi o momento em que a consciência se elevou e a luz iluminou as rachaduras do ego.\n            </p>\n        </div>\n        <div class=\"lg:col-span-6 lg:col-start-7 order-1 lg:order-2 reveal-img\" data-kid=\"1-4-2\" data-name=\"portrait image container\">\n            <img alt=\"Retrato da Alma\" class=\"w-full h-[70vh] object-cover\" data-kid=\"1-4-2-1\" data-name=\"portrait image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1600285279128-aba26bccdd00?auto=format&w=1400&q=80&fit=crop\">\n            <p class=\"kicker mt-2 pr-2 text-right\" data-kid=\"1-4-2-2\" data-name=\"portrait image caption\" style=\"color:var(--charcoal);opacity:0.6;\">\n                Retrato da Alma — fotografia, Ana Silva\n            </p>\n        </div>\n    </section>\n    \n    <section class=\"relative my-24 md:my-36 py-24 md:py-36 px-6 md:px-16 lg:px-24\" data-kid=\"1-5\" data-name=\"quote section\" style=\"background:var(--charcoal);\">\n        <blockquote class=\"font-display italic font-light leading-[1.02]\" data-kid=\"1-5-1\" data-name=\"blockquote\" style=\"color:var(--bone);font-size:clamp(2.2rem,6vw,5.2rem);margin-left:-0.5rem;\">\n            <span data-kid=\"1-5-1-1\" data-name=\"quote opening mark\" style=\"color:var(--gold);\">\n                “\n            </span>\n            Não perseguimos as respostas.\n            <br data-kid=\"1-5-1-2\" data-name=\"quote line break\">\n            Esperamos, e a verdade\n            <br data-kid=\"1-5-1-3\" data-name=\"quote line break\">\n            vem até nós.\n            <span data-kid=\"1-5-1-4\" data-name=\"quote closing mark\" style=\"color:var(--gold);\">\n                ”\n            </span>\n        </blockquote>\n        <p class=\"kicker mt-10\" data-kid=\"1-5-2\" data-name=\"quote attribution\" style=\"color:var(--gold);\">\n            — Dr. Roberto Mendes, Analista Sênior\n        </p>\n    </section>\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-10\" data-kid=\"1-6\" data-name=\"action section\">\n        <div class=\"lg:col-span-6 lg:col-start-1 reveal-img\" data-kid=\"1-6-1\" data-name=\"action image container\">\n            <img alt=\"Linhagens em movimento\" class=\"w-full h-[72vh] object-cover\" data-kid=\"1-6-1-1\" data-name=\"action image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1768434721723-e750a1372c88?auto=format&w=1600&q=80&fit=crop\">\n            <p class=\"kicker mt-2 pl-2\" data-kid=\"1-6-1-2\" data-name=\"action image caption\" style=\"color:var(--charcoal);opacity:0.6;\">\n                Linhagens em movimento — fotografia, Carlos Rocha\n            </p>\n        </div>\n        <div class=\"lg:col-span-4 lg:col-start-8 px-6 lg:px-0\" data-kid=\"1-6-2\" data-name=\"action text column\">\n            <p class=\"kicker reveal\" data-kid=\"1-6-2-1\" data-name=\"action section kicker\" style=\"color:var(--gold);\">\n                A Visão Longa\n            </p>\n            <h3 class=\"font-display text-3xl md:text-4xl mt-3 leading-tight reveal\" data-kid=\"1-6-2-2\" data-name=\"action headline\">\n                Ancestralidade\n                <br data-kid=\"1-6-2-2-1\" data-name=\"headline line break\">\n                e memória\n            </h3>\n            <p class=\"body-col mt-5 reveal\" data-kid=\"1-6-2-3\" data-name=\"action section paragraph\">\n                As linhagens de comportamento movem-se através de nós, traçando rotas que nossos ancestrais mantiveram na memória por gerações. Seguimos a uma distância respeitosa, deixando que a história dite o ritmo da descoberta.\n            </p>\n        </div>\n    </section>\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-10 mt-24 md:mt-36\" data-kid=\"1-7\" data-name=\"patient subject section\">\n        <div class=\"lg:col-span-4 lg:col-start-2 px-6 lg:px-0 order-2 lg:order-1\" data-kid=\"1-7-1\" data-name=\"patient text column\">\n            <p class=\"kicker reveal\" data-kid=\"1-7-1-1\" data-name=\"patient section kicker\" style=\"color:var(--gold);\">\n                O Sujeito Paciente\n            </p>\n            <h3 class=\"font-display text-3xl md:text-4xl mt-3 leading-tight reveal\" data-kid=\"1-7-1-2\" data-name=\"patient section headline\">\n                O instinto em\n                <br data-kid=\"1-7-1-2-1\" data-name=\"headline line break\">\n                repouso\n            </h3>\n            <p class=\"body-col mt-5 reveal\" data-kid=\"1-7-1-3\" data-name=\"patient section paragraph\">\n                A psique recompensa o paciente acima de todos os outros. Uma sombra favorita habita as margens da nossa consciência; em uma tarde de reflexão, ela se revelará e posará, imperturbável, enquanto as defesas se dissolvem gradualmente.\n            </p>\n        </div>\n        <div class=\"lg:col-span-6 lg:col-start-7 order-1 lg:order-2 reveal-img\" data-kid=\"1-7-2\" data-name=\"patient image container\">\n            <img alt=\"Sombra residente\" class=\"w-full h-[78vh] object-cover\" data-kid=\"1-7-2-1\" data-name=\"patient image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/10140719/pexels-photo-10140719.jpeg?auto=compress&cs=tinysrgb&w=1400&q=80\">\n            <p class=\"kicker mt-2 pr-2 text-right\" data-kid=\"1-7-2-2\" data-name=\"patient image caption\" style=\"color:var(--charcoal);opacity:0.6;\">\n                Sombra residente — fotografia, Lucia Santos\n            </p>\n        </div>\n    </section>\n    \n    <section class=\"relative my-24 md:my-36 py-24 md:py-36 px-6 md:px-16 lg:px-24\" data-kid=\"1-8\" data-name=\"quote section\" style=\"background:var(--charcoal);\">\n        <blockquote class=\"font-display italic font-light leading-[1.02]\" data-kid=\"1-8-1\" data-name=\"blockquote\" style=\"color:var(--bone);font-size:clamp(2rem,5.5vw,4.8rem);margin-left:-0.5rem;\">\n            <span data-kid=\"1-8-1-1\" data-name=\"quote opening mark\" style=\"color:var(--gold);\">\n                “\n            </span>\n            Cada despertar é uma página\n            <br data-kid=\"1-8-1-2\" data-name=\"quote line break\">\n            que você nunca poderá\n            <br data-kid=\"1-8-1-3\" data-name=\"quote line break\">\n            reescrever.\n            <span data-kid=\"1-8-1-4\" data-name=\"quote closing mark\" style=\"color:var(--gold);\">\n                ”\n            </span>\n        </blockquote>\n        <div class=\"gold-rule w-40 mt-10\" data-kid=\"1-8-2\" data-name=\"gold rule horizontal line\">\n        </div>\n    </section>\n    \n    <section class=\"px-6 md:px-16 lg:px-24 pt-8 pb-24 md:pb-32\" data-kid=\"1-9\" data-name=\"seasons almanac section\" id=\"seasons\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 mb-16\" data-kid=\"1-9-1\" data-name=\"almanac title grid\">\n            <div class=\"lg:col-span-3\" data-kid=\"1-9-1-1\" data-name=\"almanac column\">\n                <p class=\"kicker\" data-kid=\"1-9-1-1-1\" data-name=\"almanac kicker\" style=\"color:var(--ochre);\">\n                    Almanaque\n                </p>\n            </div>\n            <div class=\"lg:col-span-7\" data-kid=\"1-9-1-2\" data-name=\"almanac headline column\">\n                <h2 class=\"font-display text-4xl md:text-6xl leading-[0.95]\" data-kid=\"1-9-1-2-1\" data-name=\"almanac headline\">\n                    Fases da\n                    <br data-kid=\"1-9-1-2-1-1\" data-name=\"headline line break\">\n                    Transformação\n                </h2>\n            </div>\n        </div>\n        <div class=\"border-t\" data-kid=\"1-9-2\" data-name=\"almanac timeline\" style=\"border-color:var(--gold);\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-4 py-8 border-b reveal\" data-kid=\"1-9-2-1\" data-name=\"almanac phase container\" style=\"border-color:rgba(34,32,28,0.15);\">\n                <div class=\"lg:col-span-3 flex items-center gap-3\" data-kid=\"1-9-2-1-1\" data-name=\"phase period container\">\n                    <span class=\"block w-4 gold-rule mb-0.5\" data-kid=\"1-9-2-1-1-1\" data-name=\"phase bullet\">\n                    </span>\n                    <p class=\"kicker\" data-kid=\"1-9-2-1-1-2\" data-name=\"phase date text\" style=\"color:var(--gold);\">\n                        Jan – Mar\n                    </p>\n                </div>\n                <div class=\"lg:col-span-4\" data-kid=\"1-9-2-1-2\" data-name=\"phase title container\">\n                    <h4 class=\"font-display text-2xl md:text-3xl\" data-kid=\"1-9-2-1-2-1\" data-name=\"phase title\">\n                        A Incubação\n                    </h4>\n                </div>\n                <div class=\"lg:col-span-5\" data-kid=\"1-9-2-1-3\" data-name=\"phase description container\">\n                    <p class=\"body-col\" data-kid=\"1-9-2-1-3-1\" data-name=\"phase description\" style=\"font-size:17px;\">\n                        O início do processo. Pequenas mudanças na percepção e os sonhos que as acompanham. Manhãs claras e suaves — a luz mais pura do ano para o autoexame.\n                    </p>\n                </div>\n            </div>\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-4 py-8 border-b reveal\" data-kid=\"1-9-2-2\" data-name=\"almanac phase container\" style=\"border-color:rgba(34,32,28,0.15);\">\n                <div class=\"lg:col-span-3 flex items-center gap-3\" data-kid=\"1-9-2-2-1\" data-name=\"phase period container\">\n                    <span class=\"block w-4 gold-rule mb-0.5\" data-kid=\"1-9-2-2-1-1\" data-name=\"phase bullet\">\n                    </span>\n                    <p class=\"kicker\" data-kid=\"1-9-2-2-1-2\" data-name=\"phase date text\" style=\"color:var(--gold);\">\n                        Abr – Jun\n                    </p>\n                </div>\n                <div class=\"lg:col-span-4\" data-kid=\"1-9-2-2-2\" data-name=\"phase title container\">\n                    <h4 class=\"font-display text-2xl md:text-3xl\" data-kid=\"1-9-2-2-2-1\" data-name=\"phase title\">\n                        O Silêncio Esmeralda\n                    </h4>\n                </div>\n                <div class=\"lg:col-span-5\" data-kid=\"1-9-2-2-3\" data-name=\"phase description container\">\n                    <p class=\"body-col\" data-kid=\"1-9-2-2-3-1\" data-name=\"phase description\" style=\"font-size:17px;\">\n                        A introspecção traz céus dramáticos e uma mente vazia de ruídos externos. Paisagens emocionais densas e reflexões profundas. A estação do buscador consciente.\n                    </p>\n                </div>\n            </div>\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-4 py-8 border-b reveal\" data-kid=\"1-9-2-3\" data-name=\"almanac phase container\" style=\"border-color:rgba(34,32,28,0.15);\">\n                <div class=\"lg:col-span-3 flex items-center gap-3\" data-kid=\"1-9-2-3-1\" data-name=\"phase period container\">\n                    <span class=\"block w-4 gold-rule mb-0.5\" data-kid=\"1-9-2-3-1-1\" data-name=\"phase bullet\">\n                    </span>\n                    <p class=\"kicker\" data-kid=\"1-9-2-3-1-2\" data-name=\"phase date text\" style=\"color:var(--ochre);\">\n                        Jul – Out\n                    </p>\n                </div>\n                <div class=\"lg:col-span-4\" data-kid=\"1-9-2-3-2\" data-name=\"phase title container\">\n                    <h4 class=\"font-display text-2xl md:text-3xl\" data-kid=\"1-9-2-3-2-1\" data-name=\"phase title\">\n                        A Grande Travessia\n                    </h4>\n                </div>\n                <div class=\"lg:col-span-5\" data-kid=\"1-9-2-3-3\" data-name=\"phase description container\">\n                    <p class=\"body-col\" data-kid=\"1-9-2-3-3-1\" data-name=\"phase description\" style=\"font-size:17px;\">\n                        Milhares de pensamentos fluem para o centro da consciência. Poeira, impacto e as travessias difíceis — as semanas mais cobiçadas na jornada psíquica.\n                    </p>\n                </div>\n            </div>\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-4 py-8 reveal\" data-kid=\"1-9-2-4\" data-name=\"almanac phase container\">\n                <div class=\"lg:col-span-3 flex items-center gap-3\" data-kid=\"1-9-2-4-1\" data-name=\"phase period container\">\n                    <span class=\"block w-4 gold-rule mb-0.5\" data-kid=\"1-9-2-4-1-1\" data-name=\"phase bullet\">\n                    </span>\n                    <p class=\"kicker\" data-kid=\"1-9-2-4-1-2\" data-name=\"phase date text\" style=\"color:var(--gold);\">\n                        Nov – Dez\n                    </p>\n                </div>\n                <div class=\"lg:col-span-4\" data-kid=\"1-9-2-4-2\" data-name=\"phase title container\">\n                    <h4 class=\"font-display text-2xl md:text-3xl\" data-kid=\"1-9-2-4-2-1\" data-name=\"phase title\">\n                        O Retorno\n                    </h4>\n                </div>\n                <div class=\"lg:col-span-5\" data-kid=\"1-9-2-4-3\" data-name=\"phase description container\">\n                    <p class=\"body-col\" data-kid=\"1-9-2-4-3-1\" data-name=\"phase description\" style=\"font-size:17px;\">\n                        As ideias derivam para o sul novamente. Clareza recuperada e uma luz espetacular de fim de tarde sobre uma planície mental agora pacificada.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <section class=\"relative h-[80vh] w-full overflow-hidden\" data-kid=\"1-10\" data-name=\"migration band section\" style=\"background:var(--charcoal);\">\n        <img alt=\"A estação da travessia\" class=\"w-full h-[120%] object-cover\" data-kid=\"1-10-1\" data-name=\"migration background image\" decoding=\"async\" id=\"mig-img\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4252672/pexels-photo-4252672.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80\" style=\"filter:brightness(0.78);\">\n        <div class=\"absolute inset-0 pointer-events-none\" data-kid=\"1-10-2\" data-name=\"migration gradient overlay\" style=\"background:linear-gradient(to top, rgba(34,32,28,0.5) 0%, transparent 30%);\">\n        </div>\n        <p class=\"kicker absolute bottom-6 left-6 md:left-16\" data-kid=\"1-10-3\" data-name=\"migration image caption\" style=\"color:var(--bone);\">\n            A estação da travessia — fotografia, Pedro Alvares\n        </p>\n    </section>\n    \n    <section class=\"px-6 md:px-16 lg:px-24 py-24 md:py-36\" data-kid=\"1-11\" data-name=\"suites section\" id=\"suites\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 mb-16\" data-kid=\"1-11-1\" data-name=\"suites header grid\">\n            <div class=\"lg:col-span-3\" data-kid=\"1-11-1-1\" data-name=\"suites kicker container\">\n                <p class=\"kicker\" data-kid=\"1-11-1-1-1\" data-name=\"suites kicker\" style=\"color:var(--gold);\">\n                    O Espaço\n                </p>\n            </div>\n            <div class=\"lg:col-span-9\" data-kid=\"1-11-1-2\" data-name=\"suites headline container\">\n                <h2 class=\"font-display text-4xl md:text-6xl leading-[0.95]\" data-kid=\"1-11-1-2-1\" data-name=\"suites headline\">\n                    Doze modalidades,\n                    <br data-kid=\"1-11-1-2-1-1\" data-name=\"headline line break\">\n                    <span class=\"italic\" data-kid=\"1-11-1-2-1-2\" data-name=\"headline emphasis\" style=\"color:var(--acacia);\">\n                        cada uma seu refúgio\n                    </span>\n                </h2>\n            </div>\n        </div>\n        \n        <div class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-8 mb-24\" data-kid=\"1-11-2\" data-name=\"suite entry\">\n            <div class=\"lg:col-span-7 reveal-img\" data-kid=\"1-11-2-1\" data-name=\"suite image container\">\n                <img alt=\"Espaço Ilbarta Interior\" class=\"w-full h-[70vh] object-cover\" data-kid=\"1-11-2-1-1\" data-name=\"suite image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/7789602/pexels-photo-7789602.jpeg?auto=compress&cs=tinysrgb&w=1500&q=80\">\n                <p class=\"kicker mt-2 pl-2\" data-kid=\"1-11-2-1-2\" data-name=\"suite image caption\" style=\"color:var(--charcoal);opacity:0.6;\">\n                    Interior do Espaço — fotografia, Clínica Horizonte\n                </p>\n            </div>\n            <div class=\"lg:col-span-4 lg:col-start-9 px-2\" data-kid=\"1-11-2-2\" data-name=\"suite description container\">\n                <h3 class=\"font-display text-3xl md:text-4xl reveal\" data-kid=\"1-11-2-2-1\" data-name=\"suite title\">\n                    Espaço Ilbarta\n                </h3>\n                <p class=\"kicker mt-4 reveal\" data-kid=\"1-11-2-2-2\" data-name=\"suite meta kicker\" style=\"color:var(--gold);\">\n                    Análise Individual · Imersão · Foco Interno\n                </p>\n                <p class=\"body-col mt-5 reveal\" data-kid=\"1-11-2-2-3\" data-name=\"suite description\" style=\"font-size:17px;\">\n                    As paredes da mente se abrem para uma visão da sua própria essência. Estações de reflexão e um gabinete de memórias estão integrados à sua jornada pessoal.\n                </p>\n                <a class=\"link-underline kicker inline-block mt-6 reveal\" data-kid=\"1-11-2-2-4\" data-name=\"suite booking link\" href=\"#enquire\" style=\"color:var(--charcoal);\">\n                    Agendar Espaço Ilbarta →\n                </a>\n            </div>\n        </div>\n        \n        <div class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-8\" data-kid=\"1-11-3\" data-name=\"suite entry\">\n            <div class=\"lg:col-span-4 lg:col-start-1 px-2 order-2 lg:order-1\" data-kid=\"1-11-3-1\" data-name=\"suite description container\">\n                <h3 class=\"font-display text-3xl md:text-4xl reveal\" data-kid=\"1-11-3-1-1\" data-name=\"suite title\">\n                    Deck Olari\n                </h3>\n                <p class=\"kicker mt-4 reveal\" data-kid=\"1-11-3-1-2\" data-name=\"suite meta kicker\" style=\"color:var(--gold);\">\n                    Reflexão em Grupo · Conexão · Mentoria\n                </p>\n                <p class=\"body-col mt-5 reveal\" data-kid=\"1-11-3-1-3\" data-name=\"suite description\" style=\"font-size:17px;\">\n                    Um espaço de dois níveis para o buscador sério — um nível elevado de percepção voltado para as águas onde o inconsciente bebe ao entardecer.\n                </p>\n                <a class=\"link-underline kicker inline-block mt-6 reveal\" data-kid=\"1-11-3-1-4\" data-name=\"suite booking link\" href=\"#enquire\" style=\"color:var(--charcoal);\">\n                    Agendar Deck Olari →\n                </a>\n            </div>\n            <div class=\"lg:col-span-7 lg:col-start-6 order-1 lg:order-2 reveal-img\" data-kid=\"1-11-3-2\" data-name=\"suite image container\">\n                <img alt=\"Deck ao entardecer\" class=\"w-full h-[70vh] object-cover\" data-kid=\"1-11-3-2-1\" data-name=\"suite image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/36901724/pexels-photo-36901724.jpeg?auto=compress&cs=tinysrgb&w=1500&q=80\">\n                <p class=\"kicker mt-2 pr-2 text-right\" data-kid=\"1-11-3-2-2\" data-name=\"suite image caption\" style=\"color:var(--charcoal);opacity:0.6;\">\n                    Deck ao entardecer — fotografia, Mariana Costa\n                </p>\n            </div>\n        </div>\n    </section>\n    \n    <section class=\"px-6 md:px-16 lg:px-24 py-8\" data-kid=\"1-12\" data-name=\"timeline section\" id=\"timeline\" style=\"background:var(--acacia);\">\n        <div class=\"py-20 md:py-28\" data-kid=\"1-12-1\" data-name=\"timeline content container\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 mb-14\" data-kid=\"1-12-1-1\" data-name=\"timeline header grid\">\n                <div class=\"lg:col-span-3\" data-kid=\"1-12-1-1-1\" data-name=\"timeline kicker container\">\n                    <p class=\"kicker\" data-kid=\"1-12-1-1-1-1\" data-name=\"timeline kicker\" style=\"color:var(--gold);\">\n                        Um Dia de Descoberta\n                    </p>\n                </div>\n                <div class=\"lg:col-span-9\" data-kid=\"1-12-1-1-2\" data-name=\"timeline headline container\">\n                    <h2 class=\"font-display text-4xl md:text-6xl leading-[0.95]\" data-kid=\"1-12-1-1-2-1\" data-name=\"timeline headline\" style=\"color:var(--bone);\">\n                        Guiado da\n                        <br data-kid=\"1-12-1-1-2-1-1\" data-name=\"headline line break\">\n                        sombra à luz\n                    </h2>\n                </div>\n            </div>\n            <div class=\"space-y-10\" data-kid=\"1-12-1-2\" data-name=\"timeline steps container\">\n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t pt-8\" data-kid=\"1-12-1-2-1\" data-name=\"timeline step\" style=\"border-color:rgba(239,232,220,0.25);\">\n                    <div class=\"lg:col-span-3\" data-kid=\"1-12-1-2-1-1\" data-name=\"step time kicker\">\n                        <p class=\"kicker\" data-kid=\"1-12-1-2-1-1-1\" data-name=\"step time\" style=\"color:var(--gold);\">\n                            05:15 · Café e Quietude\n                        </p>\n                    </div>\n                    <div class=\"lg:col-span-7\" data-kid=\"1-12-1-2-1-2\" data-name=\"step description\">\n                        <p class=\"body-col\" data-kid=\"1-12-1-2-1-2-1\" data-name=\"step description text\" style=\"color:var(--bone);\">\n                            Uma xícara e silêncio à luz de velas. Seu guia revisa as visões da noite anterior e onde os padrões se assentaram para dormir.\n                        </p>\n                    </div>\n                </div>\n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t pt-8\" data-kid=\"1-12-1-2-2\" data-name=\"timeline step\" style=\"border-color:rgba(239,232,220,0.25);\">\n                    <div class=\"lg:col-span-3\" data-kid=\"1-12-1-2-2-1\" data-name=\"step time kicker\">\n                        <p class=\"kicker\" data-kid=\"1-12-1-2-2-1-1\" data-name=\"step time\" style=\"color:var(--gold);\">\n                            05:45 · Mergulho\n                        </p>\n                    </div>\n                    <div class=\"lg:col-span-7\" data-kid=\"1-12-1-2-2-2\" data-name=\"step description\">\n                        <p class=\"body-col\" data-kid=\"1-12-1-2-2-2-1\" data-name=\"step description text\" style=\"color:var(--bone);\">\n                            Lá fora, na escuridão, em posição antes que a cor retorne. Ferramentas prontas, foco ajustado para a hora azul da consciência por vir.\n                        </p>\n                    </div>\n                </div>\n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t pt-8\" data-kid=\"1-12-1-2-3\" data-name=\"timeline step\" style=\"border-color:rgba(239,232,220,0.25);\">\n                    <div class=\"lg:col-span-3\" data-kid=\"1-12-1-2-3-1\" data-name=\"step time kicker\">\n                        <p class=\"kicker\" data-kid=\"1-12-1-2-3-1-1\" data-name=\"step time\" style=\"color:var(--gold);\">\n                            11:00 · Nutrição\n                        </p>\n                    </div>\n                    <div class=\"lg:col-span-7\" data-kid=\"1-12-1-2-3-2\" data-name=\"step description\">\n                        <p class=\"body-col\" data-kid=\"1-12-1-2-3-2-1\" data-name=\"step description text\" style=\"color:var(--bone);\">\n                            De volta ao centro através do calor. Uma pausa sob a sombra, e a tenda de edição para processar os insights e arquétipos da manhã.\n                        </p>\n                    </div>\n                </div>\n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t pt-8\" data-kid=\"1-12-1-2-4\" data-name=\"timeline step\" style=\"border-color:rgba(239,232,220,0.25);\">\n                    <div class=\"lg:col-span-3\" data-kid=\"1-12-1-2-4-1\" data-name=\"step time kicker\">\n                        <p class=\"kicker\" data-kid=\"1-12-1-2-4-1-1\" data-name=\"step time\" style=\"color:var(--gold);\">\n                            16:00 · Hora Dourada\n                        </p>\n                    </div>\n                    <div class=\"lg:col-span-7\" data-kid=\"1-12-1-2-4-2\" data-name=\"step description\">\n                        <p class=\"body-col\" data-kid=\"1-12-1-2-4-2-1\" data-name=\"step description text\" style=\"color:var(--bone);\">\n                            O segundo mergulho, perseguindo o rastro quente da luz da tarde até que as defesas caiam e as verdades profundas comecem a se mover.\n                        </p>\n                    </div>\n                </div>\n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t border-b pb-8 pt-8\" data-kid=\"1-12-1-2-5\" data-name=\"timeline step\" style=\"border-color:rgba(239,232,220,0.25);\">\n                    <div class=\"lg:col-span-3\" data-kid=\"1-12-1-2-5-1\" data-name=\"step time kicker\">\n                        <p class=\"kicker\" data-kid=\"1-12-1-2-5-1-1\" data-name=\"step time\" style=\"color:var(--gold);\">\n                            20:00 · Ao Redor do Fogo\n                        </p>\n                    </div>\n                    <div class=\"lg:col-span-7\" data-kid=\"1-12-1-2-5-2\" data-name=\"step description\">\n                        <p class=\"body-col\" data-kid=\"1-12-1-2-5-2-1\" data-name=\"step description text\" style=\"color:var(--bone);\">\n                            Jantar sob as estrelas, e uma crítica guiada das descobertas do dia sobre uma taça de algo antigo e reconfortante.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-10 py-24 md:py-32\" data-kid=\"1-13\" data-name=\"final atmosphere section\">\n        <div class=\"lg:col-span-7 lg:col-start-1 reveal-img\" data-kid=\"1-13-1\" data-name=\"final atmosphere image container\">\n            <img alt=\"O refúgio ao anoitecer\" class=\"w-full h-[78vh] object-cover\" data-kid=\"1-13-1-1\" data-name=\"final atmosphere image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/12884330/pexels-photo-12884330.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80\">\n            <p class=\"kicker mt-2 pl-2\" data-kid=\"1-13-1-2\" data-name=\"final atmosphere caption\" style=\"color:var(--charcoal);opacity:0.6;\">\n                O refúgio ao anoitecer — fotografia, Julia Lima\n            </p>\n        </div>\n        <div class=\"lg:col-span-4 lg:col-start-9 px-6 lg:px-0\" data-kid=\"1-13-2\" data-name=\"final atmosphere quote container\">\n            <blockquote class=\"font-display italic text-3xl md:text-4xl leading-tight reveal\" data-kid=\"1-13-2-1\" data-name=\"final atmosphere blockquote\" style=\"color:var(--charcoal);\">\n                “Quando as luzes se apagam, o trabalho do dia está apenas na metade.”\n            </blockquote>\n            <p class=\"kicker mt-6 reveal\" data-kid=\"1-13-2-2\" data-name=\"final atmosphere kicker\" style=\"color:var(--gold);\">\n                A Tenda de Edição\n            </p>\n        </div>\n    </section>\n    \n    <footer data-kid=\"1-14\" data-name=\"footer\" id=\"enquire\" style=\"background:var(--charcoal);\">\n        <div class=\"px-6 md:px-16 lg:px-24 py-24 md:py-32\" data-kid=\"1-14-1\" data-name=\"footer container\">\n            <div class=\"gold-rule w-full mb-16\" data-kid=\"1-14-1-1\" data-name=\"footer gold rule\">\n            </div>\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-12\" data-kid=\"1-14-1-2\" data-name=\"footer grid\">\n                <div class=\"lg:col-span-6\" data-kid=\"1-14-1-2-1\" data-name=\"footer contact info column\">\n                    <p class=\"kicker mb-6\" data-kid=\"1-14-1-2-1-1\" data-name=\"footer kicker\" style=\"color:var(--gold);\">\n                        Inicie uma Conversa\n                    </p>\n                    <h2 class=\"font-display font-light leading-[0.95]\" data-kid=\"1-14-1-2-1-2\" data-name=\"footer headline\" style=\"color:var(--bone);font-size:clamp(2.5rem,5vw,4.5rem);\">\n                        Inicie sua jornada\n                        <br data-kid=\"1-14-1-2-1-2-1\" data-name=\"headline line break\">\n                        na\n                        <span class=\"italic\" data-kid=\"1-14-1-2-1-2-2\" data-name=\"headline emphasis\" style=\"color:var(--gold);\">\n                            consciência\n                        </span>\n                    </h2>\n                    <p class=\"body-col mt-8 max-w-md\" data-kid=\"1-14-1-2-1-3\" data-name=\"footer description\" style=\"color:var(--bone);opacity:0.8;\">\n                        Atendemos uma pessoa por vez para jornadas totalmente privadas. Os pedidos são respondidos pessoalmente pela diretoria clínica.\n                    </p>\n                    <a class=\"link-underline font-display italic text-2xl md:text-3xl inline-block mt-8\" data-kid=\"1-14-1-2-1-4\" data-name=\"footer email link\" href=\"mailto:contato@jornadainterna.pt\" style=\"color:var(--bone);\">\n                        contato@jornadainterna.pt\n                    </a>\n                </div>\n                <div class=\"lg:col-span-3 lg:col-start-8\" data-kid=\"1-14-1-2-2\" data-name=\"footer address/phone column\">\n                    <p class=\"kicker mb-5\" data-kid=\"1-14-1-2-2-1\" data-name=\"footer kicker\" style=\"color:var(--gold);\">\n                        Visite\n                    </p>\n                    <p class=\"body-col\" data-kid=\"1-14-1-2-2-2\" data-name=\"footer address\" style=\"font-size:16px;color:var(--bone);opacity:0.8;\">\n                        Centro de Análise\n                        <br data-kid=\"1-14-1-2-2-2-1\" data-name=\"address line break\">\n                        Rua da Harmonia, 122\n                        <br data-kid=\"1-14-1-2-2-2-2\" data-name=\"address line break\">\n                        Lisboa, Portugal\n                    </p>\n                    <p class=\"kicker mt-8 mb-5\" data-kid=\"1-14-1-2-2-3\" data-name=\"footer kicker\" style=\"color:var(--gold);\">\n                        Ligue\n                    </p>\n                    <p class=\"body-col\" data-kid=\"1-14-1-2-2-4\" data-name=\"footer phone\" style=\"font-size:16px;color:var(--bone);opacity:0.8;\">\n                        +351 210 000 000\n                        <br data-kid=\"1-14-1-2-2-4-1\" data-name=\"phone line break\">\n                        Diário · 09:00 – 19:00 WET\n                    </p>\n                </div>\n                <div class=\"lg:col-span-2 lg:col-start-11\" data-kid=\"1-14-1-2-3\" data-name=\"footer social links column\">\n                    <p class=\"kicker mb-5\" data-kid=\"1-14-1-2-3-1\" data-name=\"footer kicker\" style=\"color:var(--gold);\">\n                        Siga\n                    </p>\n                    <ul class=\"body-col space-y-2\" data-kid=\"1-14-1-2-3-2\" data-name=\"footer social list\" style=\"font-size:16px;color:var(--bone);opacity:0.8;\">\n                        <li data-kid=\"1-14-1-2-3-2-1\" data-name=\"list item\">\n                            <a class=\"hover:text-[var(--gold)]\" data-kid=\"1-14-1-2-3-2-1-1\" data-name=\"instagram link\" href=\"#\">\n                                Instagram\n                            </a>\n                        </li>\n                        <li data-kid=\"1-14-1-2-3-2-2\" data-name=\"list item\">\n                            <a class=\"hover:text-[var(--gold)]\" data-kid=\"1-14-1-2-3-2-2-1\" data-name=\"jornal link\" href=\"#\">\n                                O Jornal\n                            </a>\n                        </li>\n                        <li data-kid=\"1-14-1-2-3-2-3\" data-name=\"list item\">\n                            <a class=\"hover:text-[var(--gold)]\" data-kid=\"1-14-1-2-3-2-3-1\" data-name=\"filantropia link\" href=\"#\">\n                                Filantropia\n                            </a>\n                        </li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"gold-rule w-full mt-20 mb-8\" data-kid=\"1-14-1-3\" data-name=\"footer gold rule\">\n            </div>\n            <div class=\"flex flex-col md:flex-row md:items-center md:justify-between gap-4\" data-kid=\"1-14-1-4\" data-name=\"footer credits flex container\">\n                <p class=\"font-display text-2xl\" data-kid=\"1-14-1-4-1\" data-name=\"brand name\" style=\"color:var(--bone);\">\n                    Jornada Interna\n                </p>\n                <p class=\"kicker\" data-kid=\"1-14-1-4-2\" data-name=\"copyright notice\" style=\"color:var(--bone);opacity:0.5;\">\n                    © 2026 Jornada Interna · Clínica de Perfil Psicológico\n                </p>\n            </div>\n            <p class=\"kicker mt-8 leading-loose\" data-kid=\"1-14-1-5\" data-name=\"footer credits disclaimer\" style=\"color:var(--bone);opacity:0.4;\">\n                Créditos fotográficos — Ana Silva, Carlos Rocha, Lucia Santos, Pedro Alvares, Clínica Horizonte, Mariana Costa & Julia Lima. Conteúdo produzido para fins de autoconhecimento.\n            </p>\n        </div>\n    </footer>\n</div>\n\n<link data-kid=\"2\" data-name=\"lenis stylesheet link\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" rel=\"stylesheet\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"3\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"4\"></script>\n<script type=\"module\" data-kid=\"5\">\n    import Lenis from \"https://esm.sh/lenis@1\";\n\nconst lenis = new Lenis({ \n  lerp: 0.09,\n  smoothWheel: true\n});\n\nfunction raf(t) {\n  lenis.raf(t);\n  requestAnimationFrame(raf);\n}\nrequestAnimationFrame(raf);\n\ngsap.registerPlugin(ScrollTrigger);\nlenis.on('scroll', ScrollTrigger.update);\n\n// Hero parallax: image drifts, text pinned\ngsap.to(\"#hero-img\", {\n  yPercent: 16,\n  ease: \"none\",\n  scrollTrigger: {\n    trigger: \"#hero\",\n    start: \"top top\",\n    end: \"bottom top\",\n    scrub: true\n  }\n});\n\ngsap.to(\"#hero-text\", {\n  yPercent: -22,\n  opacity: 0.15,\n  ease: \"none\",\n  scrollTrigger: {\n    trigger: \"#hero\",\n    start: \"top top\",\n    end: \"bottom top\",\n    scrub: true\n  }\n});\n\n// Migration band parallax\ngsap.fromTo(\"#mig-img\", { yPercent: -8 }, {\n  yPercent: 8,\n  ease: \"none\",\n  scrollTrigger: {\n    trigger: \"#mig-img\",\n    start: \"top bottom\",\n    end: \"bottom top\",\n    scrub: true\n  }\n});\n\n// reveal text components\ngsap.utils.toArray(\".reveal\").forEach((el) => {\n  gsap.from(el, {\n    y: 34,\n    opacity: 0,\n    duration: 0.95,\n    ease: \"power3.out\",\n    scrollTrigger: {\n      trigger: el,\n      start: \"top 88%\"\n    }\n  });\n});\n\n// reveal images (clip + scale)\ngsap.utils.toArray(\".reveal-img\").forEach((el) => {\n  const img = el.querySelector(\"img\");\n  if (img) {\n    gsap.from(img, {\n      scale: 1.12,\n      duration: 1.4,\n      ease: \"power3.out\",\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 85%\"\n      }\n    });\n  }\n});\n</script>\n",
