  "nodes": {
    "node_paste_4a007abfe51f": {
      "type": "variant",
      "id": "node_paste_4a007abfe51f",
      "label": "travel-olosirkon",
      "html": "<style>html, body { margin: 0; padding: 0; } #root { display: contents; }</style>\n\n  <div id=\"root\" data-kid=\"0\"><style data-kid=\"1\">\n@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Lora:ital,wght@0,400;0,500;1,400&family=Archivo:wght@400;500;600&display=swap');\n\n:root{\n  --gold:#C8A24B;\n  --charcoal:#22201C;\n  --bone:#EFE8DC;\n  --acacia:#5C6B4A;\n  --ochre:#B05A2E;\n}\n.font-display{font-family:'Fraunces',serif;}\n.font-body{font-family:'Lora',serif;}\n.font-caps{font-family:'Archivo',sans-serif;}\n.kicker{font-family:'Archivo',sans-serif;text-transform:uppercase;letter-spacing:0.22em;font-size:11px;}\n.kicker-lg{font-family:'Archivo',sans-serif;text-transform:uppercase;letter-spacing:0.22em;font-size:12px;}\n.body-col{font-family:'Lora',serif;font-size:18.5px;line-height:1.7;}\n.reveal{opacity:1;}\n::selection{background:var(--gold);color:var(--charcoal);}\nhtml{scroll-behavior:smooth;}\n.gold-rule{height:1px;background:var(--gold);}\n.dropcap::first-letter{\n  font-family:'Fraunces',serif;\n  font-weight:400;\n  font-size:6.2rem;\n  line-height:0.78;\n  float:left;\n  color:var(--ochre);\n  padding:0.35rem 0.7rem 0 0;\n}\n.link-underline{\n  background-image:linear-gradient(var(--gold),var(--gold));\n  background-size:100% 1px;\n  background-repeat:no-repeat;\n  background-position:0 100%;\n  padding-bottom:2px;\n}\n</style>\n\n<div class=\"font-body\" style=\"background:var(--bone);color:var(--charcoal);overflow-x:clip;\" data-kid=\"2\">\n\n  \n  <nav class=\"fixed top-0 left-0 right-0 z-50\" style=\"mix-blend-mode:difference;\" data-kid=\"3\">\n    <div class=\"flex items-center justify-between px-6 md:px-12 py-5\" data-kid=\"4\">\n      <a href=\"#\" class=\"font-display text-xl tracking-wide\" style=\"color:#EFE8DC;\" data-kid=\"5\">Olosirkon</a>\n      <div class=\"hidden md:flex items-center gap-8 kicker\" style=\"color:#EFE8DC;\" data-kid=\"6\">\n        <a href=\"#essay\" class=\"hover:opacity-60\" data-kid=\"7\">The Essay</a>\n        <a href=\"#seasons\" class=\"hover:opacity-60\" data-kid=\"8\">Seasons</a>\n        <a href=\"#suites\" class=\"hover:opacity-60\" data-kid=\"9\">Suites</a>\n        <a href=\"#enquire\" class=\"hover:opacity-60\" data-kid=\"10\">Enquire</a>\n      </div>\n    </div>\n  </nav>\n\n  \n  <header id=\"hero\" class=\"relative h-screen w-full overflow-hidden\" style=\"background:var(--charcoal);\" data-kid=\"11\">\n    <div class=\"absolute inset-0 -z-0\" id=\"hero-img-wrap\" data-kid=\"12\">\n      <img id=\"hero-img\" src=\"https://images.unsplash.com/photo-1732027198030-d9ead6d14d4f?auto=format&w=2000&q=80&fit=crop\" alt=\"Dawn over the Maasai Mara\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-[120%] object-cover\" style=\"filter:brightness(0.62) saturate(1.05);\" data-kid=\"13\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n    </div>\n    <div class=\"absolute inset-0\" style=\"background:linear-gradient(115deg,rgba(34,32,28,0.78) 0%,rgba(34,32,28,0.35) 45%,rgba(34,32,28,0.15) 100%);\" data-kid=\"14\"></div>\n\n    <div id=\"hero-text\" class=\"relative z-10 h-full px-6 md:px-16 lg:px-24 flex flex-col justify-center max-w-[1100px]\" data-kid=\"15\">\n      <p class=\"kicker-lg mb-7\" style=\"color:var(--gold);\" data-kid=\"16\">A Private Conservancy · Maasai Mara, Kenya</p>\n      <h1 class=\"font-display font-light leading-[0.92] tracking-[-0.01em]\" style=\"color:var(--bone);font-size:clamp(3rem,8vw,7.5rem);\" data-kid=\"17\">\n        Where the light<br data-kid=\"18\">arrives before<br data-kid=\"19\"><span class=\"italic\" style=\"color:var(--gold);\" data-kid=\"20\">the lions</span>\n      </h1>\n      <div class=\"gold-rule w-32 mt-10 mb-7\" data-kid=\"21\"></div>\n      <p class=\"kicker max-w-md\" style=\"color:var(--bone);opacity:0.85;line-height:2;\" data-kid=\"22\">Twelve tented suites · Guided dawn drives · A camp built for the patient photographer</p>\n    </div>\n\n    <div class=\"absolute bottom-8 right-8 md:right-16 z-10 flex items-center gap-3\" data-kid=\"23\">\n      <span class=\"kicker\" style=\"color:var(--bone);\" data-kid=\"24\">Scroll</span>\n      <span class=\"block w-10 gold-rule\" data-kid=\"25\"></span>\n    </div>\n  </header>\n\n  \n  <section id=\"essay\" class=\"px-6 md:px-16 lg:px-24 py-24 md:py-36\" data-kid=\"26\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-14 lg:gap-x-12\" data-kid=\"27\">\n      <div class=\"lg:col-span-2 lg:col-start-1\" data-kid=\"28\">\n        <p class=\"kicker reveal\" style=\"color:var(--gold);\" data-kid=\"29\">Chapter One</p>\n        <p class=\"font-display italic text-2xl mt-3 reveal\" style=\"color:var(--acacia);\" data-kid=\"30\">The Waiting</p>\n      </div>\n      <div class=\"lg:col-span-5 lg:col-start-3\" data-kid=\"31\">\n        <p class=\"body-col dropcap reveal\" data-kid=\"32\">Before the sun crests the acacia line, the conservancy holds its breath. Mist pools in the seams of the land and the grass is silver with dew. We do not switch on engines yet. We listen — to the francolin, to the far cough of a leopard, to the slow turning of the world toward gold.</p>\n        <p class=\"body-col mt-6 reveal\" data-kid=\"33\">Olosirkon sits on twenty-eight thousand private acres, leased from and shared with the Maasai who have walked this ground for centuries. No more than twenty-four guests at a time. No minibuses crowding a single sleeping cat. Only the long, deliberate patience that wildlife photography demands — and the extraordinary frames it rewards.</p>\n        <p class=\"body-col mt-6 reveal\" data-kid=\"34\">Here the day is organised around light, not schedule. The first drive leaves in darkness so that you are already in position, lens steadied, when the savanna ignites.</p>\n      </div>\n      <div class=\"lg:col-span-3 lg:col-start-9 self-start\" data-kid=\"35\">\n        <p class=\"kicker reveal\" style=\"color:var(--ochre);\" data-kid=\"36\">A Marginal Note</p>\n        <p class=\"font-body italic mt-3 reveal\" style=\"font-size:15px;line-height:1.7;color:var(--acacia);\" data-kid=\"37\">Our guides are second-generation Maasai trackers, each paired with a working knowledge of long-lens craft. They read the grass the way you read a histogram.</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-10\" data-kid=\"38\">\n    <div class=\"lg:col-span-4 lg:col-start-2 px-6 lg:px-0 order-2 lg:order-1\" data-kid=\"39\">\n      <p class=\"kicker reveal\" style=\"color:var(--gold);\" data-kid=\"40\">Field Note · 06:14</p>\n      <p class=\"body-col mt-4 reveal\" data-kid=\"41\">A coalition of three males had taken the rise. We cut the engine forty metres off and waited the better part of an hour. The reward was not the kill — it was the moment one lifted his head and the light caught the dust in his mane.</p>\n    </div>\n    <div class=\"lg:col-span-6 lg:col-start-7 order-1 lg:order-2 reveal-img\" data-kid=\"42\">\n      <img src=\"https://images.pexels.com/photos/12756544/pexels-photo-12756544.jpeg?auto=compress&cs=tinysrgb&w=1400&q=80\" alt=\"Lion portrait at dawn\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-[70vh] object-cover\" data-kid=\"43\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n      <p class=\"kicker mt-2 pr-2 text-right\" style=\"color:var(--charcoal);opacity:0.6;\" data-kid=\"44\">Lion at first light — photograph, Fatih Turan</p>\n    </div>\n  </section>\n\n  \n  <section class=\"relative my-24 md:my-36 py-24 md:py-36 px-6 md:px-16 lg:px-24\" style=\"background:var(--charcoal);\" data-kid=\"45\">\n    <blockquote class=\"font-display italic font-light leading-[1.02]\" style=\"color:var(--bone);font-size:clamp(2.2rem,6vw,5.2rem);margin-left:-0.5rem;\" data-kid=\"46\">\n      <span style=\"color:var(--gold);\" data-kid=\"47\">“</span>We do not chase the animals.<br data-kid=\"48\">We wait, and the Mara<br data-kid=\"49\">comes to us.<span style=\"color:var(--gold);\" data-kid=\"50\">”</span>\n    </blockquote>\n    <p class=\"kicker mt-10\" style=\"color:var(--gold);\" data-kid=\"51\">— Joseph Sankale, Head Guide</p>\n  </section>\n\n  \n  <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-10\" data-kid=\"52\">\n    <div class=\"lg:col-span-6 lg:col-start-1 reveal-img\" data-kid=\"53\">\n      <img src=\"https://images.pexels.com/photos/22591015/pexels-photo-22591015.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80\" alt=\"Elephant herd crossing\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-[72vh] object-cover\" data-kid=\"54\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n      <p class=\"kicker mt-2 pl-2\" style=\"color:var(--charcoal);opacity:0.6;\" data-kid=\"55\">Herd on the move — photograph, Eric Kamoga</p>\n    </div>\n    <div class=\"lg:col-span-4 lg:col-start-8 px-6 lg:px-0\" data-kid=\"56\">\n      <p class=\"kicker reveal\" style=\"color:var(--gold);\" data-kid=\"57\">The Long View</p>\n      <h3 class=\"font-display text-3xl md:text-4xl mt-3 leading-tight reveal\" data-kid=\"58\">Matriarchs<br data-kid=\"59\">and memory</h3>\n      <p class=\"body-col mt-5 reveal\" data-kid=\"60\">The breeding herds move through Olosirkon in the green months, tracing routes the eldest females have held in memory for fifty years. We follow at a respectful distance, letting the herd dictate the frame.</p>\n    </div>\n  </section>\n\n  \n  <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-10 mt-24 md:mt-36\" data-kid=\"61\">\n    <div class=\"lg:col-span-4 lg:col-start-2 px-6 lg:px-0 order-2 lg:order-1\" data-kid=\"62\">\n      <p class=\"kicker reveal\" style=\"color:var(--gold);\" data-kid=\"63\">The Patient Subject</p>\n      <h3 class=\"font-display text-3xl md:text-4xl mt-3 leading-tight reveal\" data-kid=\"64\">The cat in<br data-kid=\"65\">the fig tree</h3>\n      <p class=\"body-col mt-5 reveal\" data-kid=\"66\">Leopards reward the patient above all others. A favourite female holds a territory along the riverine forest; on a good evening she will drape herself across a low fig limb and pose, unbothered, as the gold drains from the sky.</p>\n    </div>\n    <div class=\"lg:col-span-6 lg:col-start-7 order-1 lg:order-2 reveal-img\" data-kid=\"67\">\n      <img src=\"https://images.unsplash.com/photo-1688373317291-2f273bc7dc6c?auto=format&w=1400&q=80&fit=crop\" alt=\"Leopard resting\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-[78vh] object-cover\" data-kid=\"68\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n      <p class=\"kicker mt-2 pr-2 text-right\" style=\"color:var(--charcoal);opacity:0.6;\" data-kid=\"69\">Resident leopard — photograph, Denice Alex</p>\n    </div>\n  </section>\n\n  \n  <section class=\"relative my-24 md:my-36 py-24 md:py-36 px-6 md:px-16 lg:px-24\" style=\"background:var(--charcoal);\" data-kid=\"70\">\n    <blockquote class=\"font-display italic font-light leading-[1.02]\" style=\"color:var(--bone);font-size:clamp(2rem,5.5vw,4.8rem);margin-left:-0.5rem;\" data-kid=\"71\">\n      <span style=\"color:var(--gold);\" data-kid=\"72\">“</span>Every dawn is a contact sheet<br data-kid=\"73\">you will never be able<br data-kid=\"74\">to reprint.<span style=\"color:var(--gold);\" data-kid=\"75\">”</span>\n    </blockquote>\n    <div class=\"gold-rule w-40 mt-10\" data-kid=\"76\"></div>\n  </section>\n\n  \n  <section id=\"seasons\" class=\"px-6 md:px-16 lg:px-24 pt-8 pb-24 md:pb-32\" data-kid=\"77\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 mb-16\" data-kid=\"78\">\n      <div class=\"lg:col-span-3\" data-kid=\"79\">\n        <p class=\"kicker\" style=\"color:var(--ochre);\" data-kid=\"80\">Almanac</p>\n      </div>\n      <div class=\"lg:col-span-7\" data-kid=\"81\">\n        <h2 class=\"font-display text-4xl md:text-6xl leading-[0.95]\" data-kid=\"82\">Seasons &<br data-kid=\"83\">the migration</h2>\n      </div>\n    </div>\n\n    <div class=\"border-t\" style=\"border-color:var(--gold);\" data-kid=\"84\">\n      \n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-4 py-8 border-b reveal\" style=\"border-color:rgba(34,32,28,0.15);\" data-kid=\"85\">\n        <div class=\"lg:col-span-3 flex items-start gap-3\" data-kid=\"86\">\n          <span class=\"block w-4 gold-rule mt-3\" data-kid=\"87\"></span>\n          <p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"88\">Jan – Mar</p>\n        </div>\n        <div class=\"lg:col-span-4\" data-kid=\"89\"><h4 class=\"font-display text-2xl md:text-3xl\" data-kid=\"90\">The Calving Light</h4></div>\n        <div class=\"lg:col-span-5\" data-kid=\"91\"><p class=\"body-col\" style=\"font-size:17px;\" data-kid=\"92\">Short rains have greened the plains. Newborn gazelle and the predators that shadow them. Clear, soft mornings — the cleanest light of the year for portraiture.</p></div>\n      </div>\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-4 py-8 border-b reveal\" style=\"border-color:rgba(34,32,28,0.15);\" data-kid=\"93\">\n        <div class=\"lg:col-span-3 flex items-start gap-3\" data-kid=\"94\">\n          <span class=\"block w-4 gold-rule mt-3\" data-kid=\"95\"></span>\n          <p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"96\">Apr – Jun</p>\n        </div>\n        <div class=\"lg:col-span-4\" data-kid=\"97\"><h4 class=\"font-display text-2xl md:text-3xl\" data-kid=\"98\">The Emerald Quiet</h4></div>\n        <div class=\"lg:col-span-5\" data-kid=\"99\"><p class=\"body-col\" style=\"font-size:17px;\" data-kid=\"100\">The long rains bring dramatic skies and an empty conservancy. Fewer vehicles, brooding cloudscapes, and big cats lazing on the kopjes. The connoisseur's season.</p></div>\n      </div>\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-4 py-8 border-b reveal\" style=\"border-color:rgba(34,32,28,0.15);\" data-kid=\"101\">\n        <div class=\"lg:col-span-3 flex items-start gap-3\" data-kid=\"102\">\n          <span class=\"block w-4 gold-rule mt-3\" data-kid=\"103\"></span>\n          <p class=\"kicker\" style=\"color:var(--ochre);\" data-kid=\"104\">Jul – Oct</p>\n        </div>\n        <div class=\"lg:col-span-4\" data-kid=\"105\"><h4 class=\"font-display text-2xl md:text-3xl\" data-kid=\"106\">The Great Crossing</h4></div>\n        <div class=\"lg:col-span-5\" data-kid=\"107\"><p class=\"body-col\" style=\"font-size:17px;\" data-kid=\"108\">A million wildebeest pour north across the Mara. Dust, thunderhooves, and the river crossings — the most coveted twelve weeks in African photography.</p></div>\n      </div>\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-4 py-8 reveal\" data-kid=\"109\">\n        <div class=\"lg:col-span-3 flex items-start gap-3\" data-kid=\"110\">\n          <span class=\"block w-4 gold-rule mt-3\" data-kid=\"111\"></span>\n          <p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"112\">Nov – Dec</p>\n        </div>\n        <div class=\"lg:col-span-4\" data-kid=\"113\"><h4 class=\"font-display text-2xl md:text-3xl\" data-kid=\"114\">The Returning</h4></div>\n        <div class=\"lg:col-span-5\" data-kid=\"115\"><p class=\"body-col\" style=\"font-size:17px;\" data-kid=\"116\">The herds drift south again as the short rains return. Golden grass, fat predators, and spectacular evening storm light over an emptying plain.</p></div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative h-[80vh] w-full overflow-hidden\" style=\"background:var(--charcoal);\" data-kid=\"117\">\n    <img id=\"mig-img\" src=\"https://images.unsplash.com/photo-1741231896840-ffc044819fbd?auto=format&w=2000&q=80&fit=crop\" alt=\"The migration\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-[120%] object-cover\" style=\"filter:brightness(0.78);\" data-kid=\"118\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n    <p class=\"kicker absolute bottom-6 left-6 md:left-16\" style=\"color:var(--bone);\" data-kid=\"119\">The crossing season — photograph, 阿沛</p>\n  </section>\n\n  \n  <section id=\"suites\" class=\"px-6 md:px-16 lg:px-24 py-24 md:py-36\" data-kid=\"120\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 mb-16\" data-kid=\"121\">\n      <div class=\"lg:col-span-3\" data-kid=\"122\"><p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"123\">The Camp</p></div>\n      <div class=\"lg:col-span-9\" data-kid=\"124\"><h2 class=\"font-display text-4xl md:text-6xl leading-[0.95]\" data-kid=\"125\">Twelve tented suites,<br data-kid=\"126\"><span class=\"italic\" style=\"color:var(--acacia);\" data-kid=\"127\">each its own hide</span></h2></div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-8 mb-24\" data-kid=\"128\">\n      <div class=\"lg:col-span-7 reveal-img\" data-kid=\"129\">\n        <img src=\"https://images.unsplash.com/photo-1688999991151-d797021df975?auto=format&w=1500&q=80&fit=crop\" alt=\"Tented suite interior\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-[70vh] object-cover\" data-kid=\"130\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n        <p class=\"kicker mt-2 pl-2\" style=\"color:var(--charcoal);opacity:0.6;\" data-kid=\"131\">Suite interior — photograph, Ultimate Safaris Namibia</p>\n      </div>\n      <div class=\"lg:col-span-4 lg:col-start-9 px-2\" data-kid=\"132\">\n        <h3 class=\"font-display text-3xl md:text-4xl reveal\" data-kid=\"133\">The Ilbarta Suite</h3>\n        <p class=\"kicker mt-4 reveal\" style=\"color:var(--gold);\" data-kid=\"134\">68 m² · King · Private Plunge · Outdoor Bath</p>\n        <p class=\"body-col mt-5 reveal\" style=\"font-size:17px;\" data-kid=\"135\">Canvas walls roll back to a private deck facing the seasonal river. Charging stations and a dry cabinet for bodies and glass are built into the writing desk.</p>\n        <a href=\"#enquire\" class=\"link-underline kicker inline-block mt-6 reveal\" style=\"color:var(--charcoal);\" data-kid=\"136\">Reserve the Ilbarta →</a>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-8\" data-kid=\"137\">\n      <div class=\"lg:col-span-4 lg:col-start-1 px-2 order-2 lg:order-1\" data-kid=\"138\">\n        <h3 class=\"font-display text-3xl md:text-4xl reveal\" data-kid=\"139\">The Olari Deck</h3>\n        <p class=\"kicker mt-4 reveal\" style=\"color:var(--gold);\" data-kid=\"140\">82 m² · Twin / King · Star Bed · Guide Bell</p>\n        <p class=\"body-col mt-5 reveal\" style=\"font-size:17px;\" data-kid=\"141\">A two-tier deck suite for the serious photographer — a raised hide level with a fixed gimbal mount, angled at the waterhole where elephant drink at dusk.</p>\n        <a href=\"#enquire\" class=\"link-underline kicker inline-block mt-6 reveal\" style=\"color:var(--charcoal);\" data-kid=\"142\">Reserve the Olari →</a>\n      </div>\n      <div class=\"lg:col-span-7 lg:col-start-6 order-1 lg:order-2 reveal-img\" data-kid=\"143\">\n        <img src=\"https://images.pexels.com/photos/6790675/pexels-photo-6790675.jpeg?auto=compress&cs=tinysrgb&w=1500&q=80\" alt=\"Deck exterior\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-[70vh] object-cover\" data-kid=\"144\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n        <p class=\"kicker mt-2 pr-2 text-right\" style=\"color:var(--charcoal);opacity:0.6;\" data-kid=\"145\">Deck at dusk — photograph, Lelani Badenhorst</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-6 md:px-16 lg:px-24 py-8\" style=\"background:var(--acacia);\" data-kid=\"146\">\n    <div class=\"py-20 md:py-28\" data-kid=\"147\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 mb-14\" data-kid=\"148\">\n        <div class=\"lg:col-span-3\" data-kid=\"149\"><p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"150\">A Day in Camp</p></div>\n        <div class=\"lg:col-span-9\" data-kid=\"151\"><h2 class=\"font-display text-4xl md:text-6xl leading-[0.95]\" style=\"color:var(--bone);\" data-kid=\"152\">Guided from<br data-kid=\"153\">dark to dark</h2></div>\n      </div>\n\n      <div class=\"space-y-10\" data-kid=\"154\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t pt-8\" style=\"border-color:rgba(239,232,220,0.25);\" data-kid=\"155\">\n          <div class=\"lg:col-span-3\" data-kid=\"156\"><p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"157\">05:15 · Coffee</p></div>\n          <div class=\"lg:col-span-7\" data-kid=\"158\"><p class=\"body-col\" style=\"color:var(--bone);\" data-kid=\"159\">A flask and rusks by lamplight. Your guide reviews the previous evening's sightings and where the cats settled to sleep.</p></div>\n        </div>\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t pt-8\" style=\"border-color:rgba(239,232,220,0.25);\" data-kid=\"160\">\n          <div class=\"lg:col-span-3\" data-kid=\"161\"><p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"162\">05:45 · Drive</p></div>\n          <div class=\"lg:col-span-7\" data-kid=\"163\"><p class=\"body-col\" style=\"color:var(--bone);\" data-kid=\"164\">Out in the dark, in position before colour returns. Beanbags rigged, settings dialled for the blue hour exposure to come.</p></div>\n        </div>\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t pt-8\" style=\"border-color:rgba(239,232,220,0.25);\" data-kid=\"165\">\n          <div class=\"lg:col-span-3\" data-kid=\"166\"><p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"167\">11:00 · Brunch</p></div>\n          <div class=\"lg:col-span-7\" data-kid=\"168\"><p class=\"body-col\" style=\"color:var(--bone);\" data-kid=\"169\">Back to camp through the heat. A long table under the fig, a swim, and the editing tent for backing up the morning's cards.</p></div>\n        </div>\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t pt-8\" style=\"border-color:rgba(239,232,220,0.25);\" data-kid=\"170\">\n          <div class=\"lg:col-span-3\" data-kid=\"171\"><p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"172\">16:00 · Golden Hour</p></div>\n          <div class=\"lg:col-span-7\" data-kid=\"173\"><p class=\"body-col\" style=\"color:var(--bone);\" data-kid=\"174\">The second drive, chasing the warm rake of evening light until the sun is gone and the leopards begin to move.</p></div>\n        </div>\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-2 border-t border-b pb-8 pt-8\" style=\"border-color:rgba(239,232,220,0.25);\" data-kid=\"175\">\n          <div class=\"lg:col-span-3\" data-kid=\"176\"><p class=\"kicker\" style=\"color:var(--gold);\" data-kid=\"177\">20:00 · Fireside</p></div>\n          <div class=\"lg:col-span-7\" data-kid=\"178\"><p class=\"body-col\" style=\"color:var(--bone);\" data-kid=\"179\">Dinner under the stars, and a guided critique of the day's frames over a glass of something old.</p></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-10 py-24 md:py-32\" data-kid=\"180\">\n    <div class=\"lg:col-span-7 lg:col-start-1 reveal-img\" data-kid=\"181\">\n      <img src=\"https://images.unsplash.com/photo-1741850821397-5edb70742329?auto=format&w=1600&q=80&fit=crop\" alt=\"Camp at dusk\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-[78vh] object-cover\" data-kid=\"182\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n      <p class=\"kicker mt-2 pl-2\" style=\"color:var(--charcoal);opacity:0.6;\" data-kid=\"183\">Camp at dusk — photograph, Peter Thomas</p>\n    </div>\n    <div class=\"lg:col-span-4 lg:col-start-9 px-6 lg:px-0\" data-kid=\"184\">\n      <blockquote class=\"font-display italic text-3xl md:text-4xl leading-tight reveal\" style=\"color:var(--charcoal);\" data-kid=\"185\">“When the lamps come on, the work of the day is only half done.”</blockquote>\n      <p class=\"kicker mt-6 reveal\" style=\"color:var(--gold);\" data-kid=\"186\">The Editing Tent</p>\n    </div>\n  </section>\n\n  \n  <footer id=\"enquire\" style=\"background:var(--charcoal);\" data-kid=\"187\">\n    <div class=\"px-6 md:px-16 lg:px-24 py-24 md:py-32\" data-kid=\"188\">\n      <div class=\"gold-rule w-full mb-16\" data-kid=\"189\"></div>\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-12\" data-kid=\"190\">\n        <div class=\"lg:col-span-6\" data-kid=\"191\">\n          <p class=\"kicker mb-6\" style=\"color:var(--gold);\" data-kid=\"192\">Begin a Conversation</p>\n          <h2 class=\"font-display font-light leading-[0.95]\" style=\"color:var(--bone);font-size:clamp(2.5rem,5vw,4.5rem);\" data-kid=\"193\">Reserve a season<br data-kid=\"194\">in the <span class=\"italic\" style=\"color:var(--gold);\" data-kid=\"195\">Mara</span></h2>\n          <p class=\"body-col mt-8 max-w-md\" style=\"color:var(--bone);opacity:0.8;\" data-kid=\"196\">We host a single party at a time for fully private departures. Enquiries are answered personally by the camp director.</p>\n          <a href=\"mailto:reservations@olosirkon.co.ke\" class=\"link-underline font-display italic text-2xl md:text-3xl inline-block mt-8\" style=\"color:var(--bone);\" data-kid=\"197\">reservations@olosirkon.co.ke</a>\n        </div>\n        <div class=\"lg:col-span-3 lg:col-start-8\" data-kid=\"198\">\n          <p class=\"kicker mb-5\" style=\"color:var(--gold);\" data-kid=\"199\">Visit</p>\n          <p class=\"body-col\" style=\"font-size:16px;color:var(--bone);opacity:0.8;\" data-kid=\"200\">Olosirkon Conservancy<br data-kid=\"201\">Greater Maasai Mara<br data-kid=\"202\">Narok County, Kenya</p>\n          <p class=\"kicker mt-8 mb-5\" style=\"color:var(--gold);\" data-kid=\"203\">Call</p>\n          <p class=\"body-col\" style=\"font-size:16px;color:var(--bone);opacity:0.8;\" data-kid=\"204\">+254 700 000 000<br data-kid=\"205\">Daily · 07:00 – 21:00 EAT</p>\n        </div>\n        <div class=\"lg:col-span-2 lg:col-start-11\" data-kid=\"206\">\n          <p class=\"kicker mb-5\" style=\"color:var(--gold);\" data-kid=\"207\">Follow</p>\n          <ul class=\"body-col space-y-2\" style=\"font-size:16px;color:var(--bone);opacity:0.8;\" data-kid=\"208\">\n            <li data-kid=\"209\"><a href=\"#\" class=\"hover:text-[var(--gold)]\" data-kid=\"210\">Instagram</a></li>\n            <li data-kid=\"211\"><a href=\"#\" class=\"hover:text-[var(--gold)]\" data-kid=\"212\">The Journal</a></li>\n            <li data-kid=\"213\"><a href=\"#\" class=\"hover:text-[var(--gold)]\" data-kid=\"214\">Conservation</a></li>\n          </ul>\n        </div>\n      </div>\n\n      <div class=\"gold-rule w-full mt-20 mb-8\" data-kid=\"215\"></div>\n      <div class=\"flex flex-col md:flex-row md:items-center md:justify-between gap-4\" data-kid=\"216\">\n        <p class=\"font-display text-2xl\" style=\"color:var(--bone);\" data-kid=\"217\">Olosirkon</p>\n        <p class=\"kicker\" style=\"color:var(--bone);opacity:0.5;\" data-kid=\"218\">© 2026 Olosirkon Camp · A Private Conservancy</p>\n      </div>\n      <p class=\"kicker mt-8 leading-loose\" style=\"color:var(--bone);opacity:0.4;\" data-kid=\"219\">Photography credits — Selin Karahan, Fatih Turan, Eric Kamoga, Denice Alex, 阿沛, Ultimate Safaris Namibia, Lelani Badenhorst & Peter Thomas. Reproduced with thanks.</p>\n    </div>\n  </footer>\n\n</div>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"220\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"221\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"222\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"223\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"224\"></script>\n<script type=\"module\" data-kid=\"225\">\nimport Lenis from \"https://esm.sh/lenis@1\";\nconst lenis = new Lenis({ lerp:0.09 });\nfunction raf(t){ lenis.raf(t); requestAnimationFrame(raf); }\nrequestAnimationFrame(raf);\n\ngsap.registerPlugin(ScrollTrigger);\nlenis.on('scroll', ScrollTrigger.update);\n\n// Hero parallax: image drifts, text pinned\ngsap.to(\"#hero-img\", {\n  yPercent: 16, ease:\"none\",\n  scrollTrigger:{ trigger:\"#hero\", start:\"top top\", end:\"bottom top\", scrub:true }\n});\ngsap.to(\"#hero-text\", {\n  yPercent: -22, opacity:0.15, ease:\"none\",\n  scrollTrigger:{ trigger:\"#hero\", start:\"top top\", end:\"bottom top\", scrub:true }\n});\n\n// Migration band parallax\ngsap.fromTo(\"#mig-img\", { yPercent:-8 }, {\n  yPercent:8, ease:\"none\",\n  scrollTrigger:{ trigger:\"#mig-img\", start:\"top bottom\", end:\"bottom top\", scrub:true }\n});\n\n// reveal text\ngsap.utils.toArray(\".reveal\").forEach((el)=>{\n  gsap.from(el, {\n    y:34, opacity:0, duration:0.95, ease:\"power3.out\",\n    scrollTrigger:{ trigger:el, start:\"top 88%\" }\n  });\n});\n// reveal images (clip + scale)\ngsap.utils.toArray(\".reveal-img\").forEach((el)=>{\n  const img = el.querySelector(\"img\");\n  gsap.from(img, {\n    scale:1.12, duration:1.4, ease:\"power3.out\",\n    scrollTrigger:{ trigger:el, start:\"top 85%\" }\n  });\n});\n</script></div>\n  \n  \n",
