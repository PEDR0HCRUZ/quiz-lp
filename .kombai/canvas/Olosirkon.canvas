        "h": 800
      },
      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Lora:ital,wght@0,400;0,500;1,400&family=Archivo:wght@400;500;600&display=swap');\n\n:root {\n  --gold: #C8A24B;\n  --charcoal: #22201C;\n  --bone: #EFE8DC;\n  --acacia: #5C6B4A;\n  --ochre: #B05A2E;\n}\n\nbody {\n  margin: 0;\n  padding: 0;\n  background: var(--bone);\n  color: var(--charcoal);\n  font-family: 'Lora', serif;\n  overflow-x: clip;\n}\n\n.font-display { font-family: 'Fraunces', serif; }\n.font-body { font-family: 'Lora', serif; }\n.font-caps { font-family: 'Archivo', sans-serif; }\n\n.kicker {\n  font-family: 'Archivo', sans-serif;\n  text-transform: uppercase;\n  letter-spacing: 0.22em;\n  font-size: 11px;\n}\n\n.kicker-lg {\n  font-family: 'Archivo', sans-serif;\n  text-transform: uppercase;\n  letter-spacing: 0.22em;\n  font-size: 12px;\n}\n\n.body-col {\n  font-family: 'Lora', serif;\n  font-size: 18.5px;\n  line-height: 1.7;\n}\n\n.gold-rule {\n  height: 1px;\n  background: var(--gold);\n}\n\n.dropcap::first-letter {\n  font-family: 'Fraunces', serif;\n  font-weight: 400;\n  font-size: 6.2rem;\n  line-height: 0.78;\n  float: left;\n  color: var(--ochre);\n  padding: 0.35rem 0.7rem 0 0;\n}\n\n.link-underline {\n  background-image: linear-gradient(var(--gold), var(--gold));\n  background-size: 100% 1px;\n  background-repeat: no-repeat;\n  background-position: 0 100%;\n  padding-bottom: 2px;\n}\n\n.reveal { }\n</style>\n<div class=\"min-h-screen\" data-kid=\"1\" data-name=\"page layout container\">\n    \n    <nav class=\"fixed top-0 left-0 right-0 z-50 mix-blend-difference\" data-kid=\"1-1\" data-name=\"main navigation bar\" id=\"main-nav\">\n        <div class=\"flex items-center justify-between px-6 md:px-12 py-5\" data-kid=\"1-1-1\" data-name=\"navigation flex container\">\n            <a class=\"font-display text-2xl tracking-tight text-[var(--bone)]\" data-kid=\"1-1-1-1\" data-name=\"navigation logo link\" href=\"#\" id=\"nav-logo\">\n                Hjjkdsa\n            </a>\n            <div class=\"hidden md:flex items-center gap-10 kicker text-[var(--bone)]\" data-kid=\"1-1-1-2\" data-name=\"navigation links container\" id=\"nav-links\">\n                <a class=\"hover:opacity-60\" data-kid=\"1-1-1-2-1\" data-name=\"especialidades navigation link\" href=\"#especialidades\">\n                    Especialidades\n                </a>\n                <a class=\"hover:opacity-60\" data-kid=\"1-1-1-2-2\" data-name=\"metodo navigation link\" href=\"#metodo\">\n                    Método\n                </a>\n                <a class=\"hover:opacity-60\" data-kid=\"1-1-1-2-3\" data-name=\"sobre navigation link\" href=\"#sobre\">\n                    Sobre\n                </a>\n                <a class=\"hover:opacity-60\" data-kid=\"1-1-1-2-4\" data-name=\"duvidas navigation link\" href=\"#duvidas\">\n                    Dúvidas\n                </a>\n                <a class=\"px-6 py-2 border border-[var(--bone)] text-[var(--bone)] hover:bg-[var(--bone)] hover:text-[var(--charcoal)] transition-colors text-[10px] tracking-[0.3em]\" data-kid=\"1-1-1-2-5\" data-name=\"agenda call-to-action button\" href=\"#\">\n                    AGENDAR\n                </a>\n            </div>\n        </div>\n    </nav>\n    \n    <header class=\"relative h-screen w-full overflow-hidden bg-[#22201C]\" data-kid=\"1-2\" data-name=\"hero section\" id=\"hero\">\n        <div class=\"absolute inset-0 -z-0\" data-kid=\"1-2-1\" data-name=\"hero image wrapper\" id=\"hero-img-wrap\">\n            <img alt=\"Calm consultation room lighting\" class=\"w-full h-[120%] object-cover opacity-60\" data-kid=\"1-2-1-1\" data-name=\"hero background image\" decoding=\"async\" id=\"hero-img\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85?auto=format&w=2000&q=80&fit=crop\">\n        </div>\n        <div class=\"absolute inset-0\" data-kid=\"1-2-2\" data-name=\"hero gradient overlay\" style=\"background: linear-gradient(90deg, #22201C 0%, rgba(34,32,28,0.6) 40%, transparent 100%);\">\n        </div>\n        <div class=\"relative z-10 h-full px-6 md:px-16 lg:px-24 flex flex-col justify-center max-w-[1200px]\" data-kid=\"1-2-3\" data-name=\"hero content container\" id=\"hero-text\">\n            <p class=\"kicker-lg mb-7 text-[var(--gold)]\" data-kid=\"1-2-3-1\" data-name=\"hero professional kicker text\">\n                Psicanálise Clínica · Hjjkdsa\n            </p>\n            <h1 class=\"font-display font-light leading-[0.92] tracking-[-0.02em] text-[#EFE8DC] text-[clamp(3.5rem,9vw,8rem)] max-w-4xl\" data-kid=\"1-2-3-2\" data-name=\"hero headline text\">\n                Descubra o poder da\n                <span class=\"italic text-[var(--gold)]\" data-kid=\"1-2-3-2-1\" data-name=\"hero headline highlighted text\">\n                    psicanálise\n                </span>\n            </h1>\n            <div class=\"gold-rule w-32 mt-10 mb-7\" data-kid=\"1-2-3-3\" data-name=\"hero decorative gold rule\">\n            </div>\n            <p class=\"font-body text-[#EFE8DC] opacity-90 max-w-lg text-xl md:text-2xl leading-relaxed italic\" data-kid=\"1-2-3-4\" data-name=\"hero subheadline description text\">\n                Aprofunde-se em suas emoções e relacionamentos através da compreensão psicanalítica.\n            </p>\n            <div class=\"mt-12\" data-kid=\"1-2-3-5\" data-name=\"hero cta container\">\n                <a class=\"inline-flex items-center gap-4 group\" data-kid=\"1-2-3-5-1\" data-name=\"hero cta link\" href=\"#\">\n                    <span class=\"kicker text-[#EFE8DC] group-hover:text-[var(--gold)] transition-colors\" data-kid=\"1-2-3-5-1-1\" data-name=\"hero cta link label\">\n                        Falar no WhatsApp\n                    </span>\n                    <div class=\"w-12 h-px bg-[#EFE8DC] group-hover:w-20 group-hover:bg-[var(--gold)] transition-all\" data-kid=\"1-2-3-5-1-2\" data-name=\"hero cta link line animation\">\n                    </div>\n                </a>\n            </div>\n        </div>\n        <div class=\"absolute bottom-10 right-10 z-10 flex items-center gap-4\" data-kid=\"1-2-4\" data-name=\"hero explore indicator container\">\n            <span class=\"kicker text-[#EFE8DC]\" data-kid=\"1-2-4-1\" data-name=\"hero explore label\">\n                Explore\n            </span>\n            <div class=\"w-16 h-px bg-[var(--gold)]\" data-kid=\"1-2-4-2\" data-name=\"hero explore gold rule\">\n            </div>\n        </div>\n    </header>\n    \n    <section class=\"px-6 md:px-16 lg:px-24 py-24 md:py-40\" data-kid=\"1-3\" data-name=\"about essay section\" id=\"sobre\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-16 lg:gap-x-12\" data-kid=\"1-3-1\" data-name=\"about essay grid container\">\n            <div class=\"lg:col-span-2\" data-kid=\"1-3-1-1\" data-name=\"about chapter label container\">\n                <p class=\"kicker text-[var(--gold)] reveal\" data-kid=\"1-3-1-1-1\" data-name=\"about chapter kicker\">\n                    Capítulo Um\n                </p>\n                <p class=\"font-display italic text-2xl mt-3 text-[var(--acacia)] reveal\" data-kid=\"1-3-1-1-2\" data-name=\"about chapter title\">\n                    O Silêncio que Fala\n                </p>\n            </div>\n            <div class=\"lg:col-span-5 lg:col-start-4\" data-kid=\"1-3-1-2\" data-name=\"about body text container\">\n                <p class=\"body-col dropcap reveal\" data-kid=\"1-3-1-2-1\" data-name=\"about primary paragraph with dropcap\">\n                    Antes que a primeira palavra seja dita, o consultório já guarda um convite à escuta profunda. Em um cotidiano acelerado e repleto de respostas prontas, a psicanálise propõe um desvio: o tempo da subjetividade. Não buscamos apenas aliviar sintomas, mas compreender a gramática oculta que rege suas escolhas e afetos.\n                </p>\n                <p class=\"body-col mt-8 reveal\" data-kid=\"1-3-1-2-2\" data-name=\"about secondary paragraph\">\n                    Hjjkdsa atua sob a ética freudiano-lacaniana, onde o paciente é convidado a dizer tudo o que lhe vier à mente. É nesse exercício de associação livre que as repetições se revelam e novos caminhos de desejo podem ser traçados.\n                </p>\n            </div>\n            <div class=\"lg:col-span-3 lg:col-start-10 self-start\" data-kid=\"1-3-1-3\" data-name=\"about secondary column container\">\n                <p class=\"kicker text-[var(--ochre)] reveal\" data-kid=\"1-3-1-3-1\" data-name=\"about practice kicker\">\n                    A Prática\n                </p>\n                <p class=\"font-body italic mt-4 text-base leading-relaxed text-[var(--acacia)] reveal\" data-kid=\"1-3-1-3-2\" data-name=\"about quote paragraph\">\n                    \"A psicanálise é, em essência, uma cura pelo amor.\" — Esta máxima nos lembra que o vínculo terapêutico é o solo onde a transformação se torna possível.\n                </p>\n            </div>\n        </div>\n    </section>\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-12 py-12 md:py-24\" data-kid=\"1-4\" data-name=\"reflection section\">\n        <div class=\"lg:col-span-4 lg:col-start-2 px-6 lg:px-0 order-2 lg:order-1\" data-kid=\"1-4-1\" data-name=\"reflection text container\">\n            <p class=\"kicker text-[var(--gold)] reveal\" data-kid=\"1-4-1-1\" data-name=\"reflection section kicker\">\n                Presença e Escuta\n            </p>\n            <p class=\"body-col mt-6 reveal\" data-kid=\"1-4-1-2\" data-name=\"reflection section body paragraph\">\n                O setting analítico é um espaço de suspensão. Onde o julgamento dá lugar à curiosidade analítica. Cada gesto, cada pausa e cada esquecimento tornam-se material de trabalho para a construção de uma vida mais autêntica.\n            </p>\n        </div>\n        <div class=\"lg:col-span-6 lg:col-start-7 order-1 lg:order-2 reveal-img overflow-hidden\" data-kid=\"1-4-2\" data-name=\"reflection image container\">\n            <img alt=\"Person in reflection\" class=\"w-full h-[70vh] object-cover\" data-kid=\"1-4-2-1\" data-name=\"reflection feature image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4101143/pexels-photo-4101143.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80\">\n            <p class=\"kicker mt-4 pr-6 text-right text-[var(--charcoal)]/40\" data-kid=\"1-4-2-2\" data-name=\"reflection image credit caption\">\n                A subjetividade em foco — Fotografia, Hjjkdsa\n            </p>\n        </div>\n    </section>\n    \n    <section class=\"relative my-24 md:my-40 py-24 md:py-40 px-6 md:px-16 lg:px-24 bg-[#22201C]\" data-kid=\"1-5\" data-name=\"quote section\">\n        <blockquote class=\"font-display italic font-light leading-[1.05] text-[#EFE8DC] text-[clamp(2.5rem,5.5vw,5rem)] -ml-2 reveal max-w-5xl\" data-kid=\"1-5-1\" data-name=\"quote block\">\n            <span class=\"text-[var(--gold)]\" data-kid=\"1-5-1-1\" data-name=\"opening quotation mark\">\n                “\n            </span>\n            Olhe para as profundezas da sua própria alma e aprenda primeiro a se\n            <span class=\"text-[var(--gold)] italic\" data-kid=\"1-5-1-2\" data-name=\"quote emphasis word\">\n                conhecer\n            </span>\n            .\n            <span class=\"text-[var(--gold)]\" data-kid=\"1-5-1-3\" data-name=\"closing quotation mark\">\n                ”\n            </span>\n        </blockquote>\n        <p class=\"kicker mt-12 text-[var(--gold)] reveal\" data-kid=\"1-5-2\" data-name=\"quote author name\">\n            — Sigmund Freud\n        </p>\n    </section>\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-12 items-center gap-y-12 mb-24 md:mb-40\" data-kid=\"1-6\" data-name=\"method section\" id=\"metodo\">\n        <div class=\"lg:col-span-7 lg:col-start-1 reveal-img overflow-hidden\" data-kid=\"1-6-1\" data-name=\"method image container\">\n            <img alt=\"Hands connecting\" class=\"w-full h-[75vh] object-cover grayscale-[20%]\" data-kid=\"1-6-1-1\" data-name=\"method feature image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/7176319/pexels-photo-7176319.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80\">\n            <p class=\"kicker mt-4 pl-6 text-[var(--charcoal)]/40\" data-kid=\"1-6-1-2\" data-name=\"method image credit caption\">\n                O laço analítico — Fotografia, Hjjkdsa\n            </p>\n        </div>\n        <div class=\"lg:col-span-4 lg:col-start-9 px-6 lg:px-0\" data-kid=\"1-6-2\" data-name=\"method text container\">\n            <p class=\"kicker text-[var(--gold)] reveal\" data-kid=\"1-6-2-1\" data-name=\"method section kicker\">\n                O Método\n            </p>\n            <h2 class=\"font-display text-4xl md:text-5xl mt-4 leading-tight reveal text-[color:var(--charcoal)]\" data-kid=\"1-6-2-2\" data-name=\"method section headline\">\n                Associação Livre e\n                <span class=\"italic\" data-kid=\"1-6-2-2-1\" data-name=\"method headline emphasis\">\n                    Transferência\n                </span>\n            </h2>\n            <p class=\"body-col mt-6 reveal\" data-kid=\"1-6-2-3\" data-name=\"method section body paragraph\">\n                Não oferecemos conselhos ou fórmulas de felicidade. Oferecemos um método: a fala livre. É através dela que você poderá reencontrar a sua própria voz, muitas vezes abafada por expectativas externas e traumas do passado.\n            </p>\n        </div>\n    </section>\n    \n    <section class=\"px-6 md:px-16 lg:px-24 py-24 md:py-40 bg-white/30 border-y border-[var(--gold)]/10\" data-kid=\"1-7\" data-name=\"areas section\" id=\"especialidades\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20\" data-kid=\"1-7-1\" data-name=\"areas header container\">\n            <div class=\"lg:col-span-8\" data-kid=\"1-7-1-1\" data-name=\"areas title container\">\n                <h2 class=\"font-display text-4xl md:text-7xl leading-[0.9] text-[color:var(--charcoal)] reveal\" data-kid=\"1-7-1-1-1\" data-name=\"areas section headline\">\n                    Áreas de\n                    <span class=\"italic text-[var(--gold)]\" data-kid=\"1-7-1-1-1-1\" data-name=\"areas headline emphasis\">\n                        Aprofundamento\n                    </span>\n                </h2>\n            </div>\n            <div class=\"lg:col-span-4 flex items-end\" data-kid=\"1-7-1-2\" data-name=\"areas kicker container\">\n                <p class=\"kicker text-[var(--ochre)] mb-2 reveal\" data-kid=\"1-7-1-2-1\" data-name=\"areas section kicker\">\n                    Frentes Clínicas\n                </p>\n            </div>\n        </div>\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-24\" data-kid=\"1-7-2\" data-name=\"areas grid container\">\n            <div class=\"reveal\" data-kid=\"1-7-2-1\" data-name=\"area card one\">\n                <div class=\"flex items-baseline gap-6 mb-6\" data-kid=\"1-7-2-1-1\" data-name=\"area header container\">\n                    <span class=\"font-display text-5xl text-[var(--gold)]/30\" data-kid=\"1-7-2-1-1-1\" data-name=\"area number label\">\n                        01\n                    </span>\n                    <h4 class=\"font-display text-3xl\" data-kid=\"1-7-2-1-1-2\" data-name=\"area card title\">\n                        Relacionamentos\n                    </h4>\n                </div>\n                <p class=\"body-col text-lg opacity-80\" data-kid=\"1-7-2-1-2\" data-name=\"area card body text\">\n                    Investigação de padrões repetitivos em laços amorosos e familiares. Compreensão das dinâmicas de dependência e conflito.\n                </p>\n            </div>\n            <div class=\"reveal md:mt-24\" data-kid=\"1-7-2-2\" data-name=\"area card two\">\n                <div class=\"flex items-baseline gap-6 mb-6\" data-kid=\"1-7-2-2-1\" data-name=\"area header container\">\n                    <span class=\"font-display text-5xl text-[var(--gold)]/30\" data-kid=\"1-7-2-2-1-1\" data-name=\"area number label\">\n                        02\n                    </span>\n                    <h4 class=\"font-display text-3xl\" data-kid=\"1-7-2-2-1-2\" data-name=\"area card title\">\n                        Angústia e Ansiedade\n                    </h4>\n                </div>\n                <p class=\"body-col text-lg opacity-80\" data-kid=\"1-7-2-2-2\" data-name=\"area card body text\">\n                    Trabalho sobre o mal-estar contemporâneo e o sentimento de vazio que muitas vezes acompanha a vida produtiva.\n                </p>\n            </div>\n            <div class=\"reveal\" data-kid=\"1-7-2-3\" data-name=\"area card three\">\n                <div class=\"flex items-baseline gap-6 mb-6\" data-kid=\"1-7-2-3-1\" data-name=\"area header container\">\n                    <span class=\"font-display text-5xl text-[var(--gold)]/30\" data-kid=\"1-7-2-3-1-1\" data-name=\"area number label\">\n                        03\n                    </span>\n                    <h4 class=\"font-display text-3xl\" data-kid=\"1-7-2-3-1-2\" data-name=\"area card title\">\n                        Carreira e Identidade\n                    </h4>\n                </div>\n                <p class=\"body-col text-lg opacity-80\" data-kid=\"1-7-2-3-2\" data-name=\"area card body text\">\n                    Dificuldades de posicionamento profissional e a busca por um propósito que faça sentido para além do capital.\n                </p>\n            </div>\n            <div class=\"reveal md:mt-24\" data-kid=\"1-7-2-4\" data-name=\"area card four\">\n                <div class=\"flex items-baseline gap-6 mb-6\" data-kid=\"1-7-2-4-1\" data-name=\"area header container\">\n                    <span class=\"font-display text-5xl text-[var(--gold)]/30\" data-kid=\"1-7-2-4-1-1\" data-name=\"area number label\">\n                        04\n                    </span>\n                    <h4 class=\"font-display text-3xl\" data-kid=\"1-7-2-4-1-2\" data-name=\"area card title\">\n                        Processos de Luto\n                    </h4>\n                </div>\n                <p class=\"body-col text-lg opacity-80\" data-kid=\"1-7-2-4-2\" data-name=\"area card body text\">\n                    Elaboração de perdas — sejam elas de pessoas queridas, de fases da vida ou de versões de si mesmo.\n                </p>\n            </div>\n        </div>\n    </section>\n    \n    <section class=\"px-6 md:px-16 lg:px-24 py-24 md:py-40 relative\" data-kid=\"1-8\" data-name=\"consultation options section\" id=\"duvidas\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-24\" data-kid=\"1-8-1\" data-name=\"options grid container\">\n            <div class=\"lg:col-span-7\" data-kid=\"1-8-1-1\" data-name=\"presential options column\">\n                <div class=\"reveal-img overflow-hidden mb-8 bg-[#D3D3D3]\" data-kid=\"1-8-1-1-1\" data-name=\"presential image wrapper\">\n                    <img alt=\"Consultation room\" class=\"w-full h-[60vh] object-cover\" data-kid=\"1-8-1-1-1-1\" data-name=\"presential consultation image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1493663284031-b7e3aefcae8e?auto=format&w=1600&q=80&fit=crop\">\n                </div>\n                <h3 class=\"font-display text-4xl reveal text-[color:var(--charcoal)]\" data-kid=\"1-8-1-1-2\" data-name=\"presential option title\">\n                    Presencial Porto Alegre\n                </h3>\n                <p class=\"body-col mt-4 max-w-xl reveal\" data-kid=\"1-8-1-1-3\" data-name=\"presential option description\">\n                    Sessões realizadas em consultório privativo no bairro Auxiliadora. Um ambiente neutro e seguro projetado para o rigor da escuta analítica.\n                </p>\n                <div class=\"mt-8 border-l border-[var(--gold)] pl-8 py-1 reveal\" data-kid=\"1-8-1-1-4\" data-name=\"presential investment container\">\n                    <p class=\"kicker text-[var(--gold)]\" data-kid=\"1-8-1-1-4-1\" data-name=\"presential investment label\">\n                        Investimento\n                    </p>\n                    <p class=\"font-display text-3xl mt-1 text-[color:var(--charcoal)]\" data-kid=\"1-8-1-1-4-2\" data-name=\"presential investment price text\">\n                        R$ 250\n                        <span class=\"text-base font-body italic opacity-60\" data-kid=\"1-8-1-1-4-2-1\" data-name=\"presential per session label\">\n                            por sessão\n                        </span>\n                    </p>\n                </div>\n            </div>\n            <div class=\"lg:col-span-4 lg:col-start-9 lg:mt-48\" data-kid=\"1-8-1-2\" data-name=\"online options column\">\n                <div class=\"reveal-img overflow-hidden mb-8 bg-[#D3D3D3]\" data-kid=\"1-8-1-2-1\" data-name=\"online image wrapper\">\n                    <img alt=\"Therapeutic environment\" class=\"w-full h-[50vh] object-cover grayscale\" data-kid=\"1-8-1-2-1-1\" data-name=\"online consultation image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/7176026/pexels-photo-7176026.jpeg?auto=compress&cs=tinysrgb&w=1200\">\n                </div>\n                <h3 class=\"font-display text-4xl reveal text-[color:var(--charcoal)]\" data-kid=\"1-8-1-2-2\" data-name=\"online option title\">\n                    Atendimento Online\n                </h3>\n                <p class=\"body-col mt-4 reveal\" data-kid=\"1-8-1-2-3\" data-name=\"online option description\">\n                    A profundidade da psicanálise acessível de qualquer lugar do mundo. Sessões por vídeo com absoluto sigilo e infraestrutura digital segura.\n                </p>\n                <div class=\"mt-8 border-l border-[var(--gold)] pl-8 py-1 reveal\" data-kid=\"1-8-1-2-4\" data-name=\"online investment container\">\n                    <p class=\"kicker text-[var(--gold)]\" data-kid=\"1-8-1-2-4-1\" data-name=\"online investment label\">\n                        Investimento\n                    </p>\n                    <p class=\"font-display text-3xl mt-1 text-[color:var(--charcoal)]\" data-kid=\"1-8-1-2-4-2\" data-name=\"online investment price text\">\n                        R$ 250\n                        <span class=\"text-base font-body italic opacity-60\" data-kid=\"1-8-1-2-4-2-1\" data-name=\"online per session label\">\n                            por sessão\n                        </span>\n                    </p>\n                </div>\n                <a class=\"link-underline kicker inline-block mt-8 text-[color:var(--charcoal)] reveal\" data-kid=\"1-8-1-2-5\" data-name=\"online cta link\" href=\"#\">\n                    Conversar no WhatsApp →\n                </a>\n            </div>\n        </div>\n    </section>\n    \n    <section class=\"py-32 md:py-52 bg-[#22201C] text-[#EFE8DC] overflow-hidden\" data-kid=\"1-9\" data-name=\"final cta section\">\n        <div class=\"px-6 md:px-16 lg:px-24\" data-kid=\"1-9-1\" data-name=\"final cta content container\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12\" data-kid=\"1-9-1-1\" data-name=\"final cta grid\">\n                <div class=\"lg:col-span-8\" data-kid=\"1-9-1-1-1\" data-name=\"final cta text column\">\n                    <p class=\"kicker text-[var(--gold)] mb-8 reveal\" data-kid=\"1-9-1-1-1-1\" data-name=\"final cta kicker\">\n                        O próximo passo\n                    </p>\n                    <h2 class=\"font-display text-5xl md:text-8xl leading-[0.9] reveal text-[color:#EFE8DC]\" data-kid=\"1-9-1-1-1-2\" data-name=\"final cta headline\">\n                        A cura começa pela\n                        <span class=\"italic text-[var(--gold)]\" data-kid=\"1-9-1-1-1-2-1\" data-name=\"final cta headline emphasis\">\n                            palavra\n                        </span>\n                    </h2>\n                </div>\n                <div class=\"lg:col-span-4 flex flex-col justify-end\" data-kid=\"1-9-1-1-2\" data-name=\"final cta button column\">\n                    <p class=\"body-col text-xl italic mb-10 reveal opacity-80\" data-kid=\"1-9-1-1-2-1\" data-name=\"final cta subheadline description\">\n                        Agende uma conversa inicial para compreender como o processo psicanalítico pode atuar em sua vida.\n                    </p>\n                    <a class=\"inline-block py-6 px-10 border border-[var(--gold)] text-[var(--gold)] hover:bg-[var(--gold)] hover:text-[#22201C] transition-colors font-display text-2xl text-center reveal\" data-kid=\"1-9-1-1-2-2\" data-name=\"final cta button\" href=\"#\">\n                        Agendar via WhatsApp\n                    </a>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <footer class=\"bg-[#22201C] text-[#EFE8DC]\" data-kid=\"1-10\" data-name=\"footer section\">\n        <div class=\"px-6 md:px-16 lg:px-24 py-24 md:py-32\" data-kid=\"1-10-1\" data-name=\"footer container\">\n            <div class=\"gold-rule w-full mb-16 opacity-30\" data-kid=\"1-10-1-1\" data-name=\"footer top gold rule\">\n            </div>\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-16\" data-kid=\"1-10-1-2\" data-name=\"footer content grid\">\n                <div class=\"lg:col-span-6\" data-kid=\"1-10-1-2-1\" data-name=\"footer profile info column\">\n                    <p class=\"kicker mb-6 text-[var(--gold)]\" data-kid=\"1-10-1-2-1-1\" data-name=\"footer profile category kicker\">\n                        Psicoterapia\n                    </p>\n                    <h2 class=\"font-display font-light leading-[0.95] text-[clamp(2.5rem,5vw,4rem)] text-[color:#EFE8DC]\" data-kid=\"1-10-1-2-1-2\" data-name=\"footer profile title\">\n                        Hjjkdsa\n                        <span class=\"italic text-[var(--gold)]\" data-kid=\"1-10-1-2-1-2-1\" data-name=\"footer profile emphasis\">\n                            Psicanálise\n                        </span>\n                    </h2>\n                    <p class=\"body-col mt-8 max-w-md opacity-70\" data-kid=\"1-10-1-2-1-3\" data-name=\"footer profile bio text\">\n                        Psicólogo Clínico — CRP 07/324423. Atendimento híbrido especializado em subjetividade e sofrimento psíquico.\n                    </p>\n                    <a class=\"link-underline font-display italic text-2xl md:text-3xl inline-block mt-8 hover:text-[var(--gold)] transition-colors text-[color:#EFE8DC]\" data-kid=\"1-10-1-2-1-4\" data-name=\"footer contact email link\" href=\"mailto:contato@hjjkdsa.com.br\">\n                        contato@hjjkdsa.com.br\n                    </a>\n                </div>\n                <div class=\"lg:col-span-3 lg:col-start-8\" data-kid=\"1-10-1-2-2\" data-name=\"footer location column\">\n                    <p class=\"kicker mb-6 text-[var(--gold)]\" data-kid=\"1-10-1-2-2-1\" data-name=\"footer location kicker\">\n                        Porto Alegre\n                    </p>\n                    <p class=\"body-col text-base opacity-70 leading-relaxed\" data-kid=\"1-10-1-2-2-2\" data-name=\"footer address text\">\n                        Av. Carlos Gomes, 1492\n                        <br data-kid=\"1-10-1-2-2-2-1\" data-name=\"address line break\">\n                        Auxiliadora, CEP 90480-002\n                    </p>\n                    <p class=\"kicker mt-10 mb-6 text-[var(--gold)]\" data-kid=\"1-10-1-2-2-3\" data-name=\"footer availability kicker\">\n                        Disponibilidade\n                    </p>\n                    <p class=\"body-col text-base opacity-70 leading-relaxed\" data-kid=\"1-10-1-2-2-4\" data-name=\"footer availability text\">\n                        Segunda a Sexta\n                        <br data-kid=\"1-10-1-2-2-4-1\" data-name=\"availability line break\">\n                        Presencial e Online\n                    </p>\n                </div>\n                <div class=\"lg:col-span-2 lg:col-start-11\" data-kid=\"1-10-1-2-3\" data-name=\"footer navigation column\">\n                    <p class=\"kicker mb-6 text-[var(--gold)]\" data-kid=\"1-10-1-2-3-1\" data-name=\"footer nav kicker\">\n                        Acesso\n                    </p>\n                    <ul class=\"body-col text-base space-y-3 opacity-70\" data-kid=\"1-10-1-2-3-2\" data-name=\"footer navigation list\">\n                        <li data-kid=\"1-10-1-2-3-2-1\" data-name=\"especialidades footer item\">\n                            <a class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"1-10-1-2-3-2-1-1\" data-name=\"especialidades footer link\" href=\"#especialidades\">\n                                Especialidades\n                            </a>\n                        </li>\n                        <li data-kid=\"1-10-1-2-3-2-2\" data-name=\"metodo footer item\">\n                            <a class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"1-10-1-2-3-2-2-1\" data-name=\"metodo footer link\" href=\"#metodo\">\n                                Método\n                            </a>\n                        </li>\n                        <li data-kid=\"1-10-1-2-3-2-3\" data-name=\"sobre footer item\">\n                            <a class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"1-10-1-2-3-2-3-1\" data-name=\"sobre footer link\" href=\"#sobre\">\n                                Sobre\n                            </a>\n                        </li>\n                        <li data-kid=\"1-10-1-2-3-2-4\" data-name=\"duvidas footer item\">\n                            <a class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"1-10-1-2-3-2-4-1\" data-name=\"duvidas footer link\" href=\"#duvidas\">\n                                Dúvidas\n                            </a>\n                        </li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"gold-rule w-full mt-24 mb-10 opacity-30\" data-kid=\"1-10-1-3\" data-name=\"footer bottom gold rule\">\n            </div>\n            <div class=\"flex flex-col md:flex-row md:items-center md:justify-between gap-6\" data-kid=\"1-10-1-4\" data-name=\"footer copyright container\">\n                <div class=\"flex flex-col gap-1\" data-kid=\"1-10-1-4-1\" data-name=\"footer branding container\">\n                    <p class=\"font-display text-2xl tracking-tight text-[color:#EFE8DC]\" data-kid=\"1-10-1-4-1-1\" data-name=\"footer logo text\">\n                        Hjjkdsa\n                    </p>\n                    <p class=\"kicker text-[8px] opacity-40\" data-kid=\"1-10-1-4-1-2\" data-name=\"footer credentials sub-text\">\n                        Psicólogo · CRP 07/324423 · híbrido\n                    </p>\n                </div>\n                <div class=\"flex flex-col md:items-end gap-2\" data-kid=\"1-10-1-4-2\" data-name=\"footer copyright text container\">\n                    <p class=\"kicker text-[10px] opacity-50\" data-kid=\"1-10-1-4-2-1\" data-name=\"footer copyright text\">\n                        © 2026 Todos os direitos reservados\n                    </p>\n                </div>\n            </div>\n        </div>\n    </footer>\n</div>\n<link data-kid=\"2\" data-name=\"external stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" rel=\"stylesheet\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"3\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"4\"></script>\n<script type=\"module\" data-kid=\"5\">\n    import Lenis from \"https://esm.sh/lenis@1\";\nconst lenis = new Lenis({ lerp: 0.06, smoothWheel: true });\nfunction raf(t) { lenis.raf(t); requestAnimationFrame(raf); }\nrequestAnimationFrame(raf);\n\ngsap.registerPlugin(ScrollTrigger);\nlenis.on('scroll', ScrollTrigger.update);\n\n// Hero Parallax\ngsap.to(\"#hero-img\", {\n  yPercent: 16,\n  ease: \"none\",\n  scrollTrigger: {\n    trigger: \"#hero\",\n    start: \"top top\",\n    end: \"bottom top\",\n    scrub: true\n  }\n});\n\ngsap.to(\"#hero-text\", {\n  yPercent: -22,\n  opacity: 0.15,\n  ease: \"none\",\n  scrollTrigger: {\n    trigger: \"#hero\",\n    start: \"top top\",\n    end: \"bottom top\",\n    scrub: true\n  }\n});\n\n// Reveal animations\ngsap.utils.toArray(\".reveal\").forEach((el) => {\n  gsap.from(el, {\n    y: 40,\n    opacity: 0,\n    duration: 1.2,\n    ease: \"power3.out\",\n    scrollTrigger: {\n      trigger: el,\n      start: \"top 90%\",\n      toggleActions: \"play none none none\"\n    }\n  });\n});\n\n// Image reveals with subtle scale\ngsap.utils.toArray(\".reveal-img\").forEach((el) => {\n  const img = el.querySelector(\"img\");\n  gsap.from(img, {\n    scale: 1.15,\n    duration: 1.8,\n    ease: \"power2.out\",\n    scrollTrigger: {\n      trigger: el,\n      start: \"top 85%\",\n      toggleActions: \"play none none none\"\n    }\n  });\n});\n</script>\n>>>>>>> REPLACE\n",
