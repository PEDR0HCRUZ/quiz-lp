      },
      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&family=Courier+Prime:ital,wght@0,400;0,700;1,400&display=swap');\n\n  :root {\n    --linen: #E8E1D2;\n    --moss: #6B7B52;\n    --clay: #B5694B;\n    --bark: #2E2A24;\n  }\n\n  .font-display { font-family: 'Fraunces', serif; }\n  .font-body { font-family: 'Atkinson Hyperlegible', sans-serif; }\n  .font-mono { font-family: 'Courier Prime', monospace; }\n\n  #tk-root { background: var(--linen); color: var(--bark); }\n\n  .grain {\n    position: absolute; inset: 0; pointer-events: none; opacity: .07; z-index: 50; mix-blend-mode: multiply;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3BaseFilter id='f'%3B%3BfeTurbulence type='fractalNoise' baseFrequency='.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)'/%3E%3C/svg%3E\");\n  }\n\n  .dashed-stitch { border-left: 1.5px dashed rgba(46, 42, 36, 0.35); }\n  .stitch-row { height: 1.5px; width: 100%; background-image: repeating-linear-gradient(90deg, rgba(46, 42, 36, 0.4) 0 10px, transparent 10px 20px); }\n\n  .wax-seal {\n    filter: drop-shadow(0 6px 10px rgba(46, 42, 36, 0.35));\n    width: 120px; height: 120px;\n    background: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/wax-seal.svg') no-repeat center/contain;\n    filter: invert(38%) sepia(40%) saturate(900%) hue-rotate(330deg) brightness(85%);\n  }\n\n  .polaroid {\n    background: #FBF8F1;\n    padding: 12px 12px 48px;\n    box-shadow: 0 12px 26px rgba(20, 18, 14, 0.25);\n    cursor: grab;\n    will-change: transform;\n    z-index: 10;\n  }\n  .polaroid:active { cursor: grabbing; z-index: 20; }\n\n  .vine-line {\n    position: absolute; left: 50%; top: 0; bottom: 0; transform: translateX(-50%); width: 2px;\n    background-image: repeating-linear-gradient(0deg, var(--bark) 0, var(--bark) 10px, transparent 10px, transparent 20px);\n    opacity: 0.15;\n  }\n\n  .btn-clay {\n    background-color: var(--clay);\n    color: var(--linen);\n    font-family: 'Courier Prime', monospace;\n    text-transform: uppercase;\n    letter-spacing: 0.2em;\n    padding: 1rem 2rem;\n    transition: all 0.3s ease;\n  }\n  .btn-clay:hover { filter: brightness(1.1); }\n\n  .ledger-item { border-bottom: 1px dashed rgba(46, 42, 36, 0.15); padding: 2rem 0; }\n  \n  details summary::-webkit-details-marker { display: none; }\n  \n  /* Smooth Accordion */\n  details .details-content {\n    display: grid;\n    grid-template-rows: 0fr;\n    transition: grid-template-rows 0.4s ease-out;\n  }\n  details[open] .details-content {\n    grid-template-rows: 1fr;\n  }\n  .details-inner {\n    overflow: hidden;\n  }\n\n  /* Lenis CSS */\n  html.lenis { height: auto; }\n  .lenis.lenis-smooth { scroll-behavior: auto !important; }\n  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }\n  .lenis.lenis-stopped { overflow: hidden; }\n  .lenis.lenis-scrolling iframe { pointer-events: none; }\n</style>\n<link data-kid=\"1\" data-name=\"lenis scroll library stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" rel=\"stylesheet\">\n<div class=\"font-body overflow-x-clip relative\" data-kid=\"2\" data-name=\"page wrapper\" id=\"tk-root\">\n    <div class=\"grain\" data-kid=\"2-1\" data-name=\"texture grain overlay\">\n    </div>\n    \n    <nav class=\"relative z-50 flex justify-between items-center px-8 md:px-16 py-8 border-b border-dashed border-[var(--bark)]/10\" data-kid=\"2-2\" data-name=\"main navigation header\">\n        <div class=\"font-display text-2xl font-600 tracking-tight italic\" data-kid=\"2-2-1\" data-name=\"logo text\">\n            Elena Silva\n        </div>\n        <div class=\"hidden md:flex gap-12 font-mono text-[10px] tracking-[0.4em] uppercase opacity-60\" data-kid=\"2-2-2\" data-name=\"navigation menu links\">\n            <a class=\"hover:text-[var(--clay)] transition-colors\" data-kid=\"2-2-2-1\" data-name=\"navigation link specialties\" href=\"#specialties\">\n                Especialidades\n            </a>\n            <a class=\"hover:text-[var(--clay)] transition-colors\" data-kid=\"2-2-2-2\" data-name=\"navigation link method\" href=\"#journey\">\n                Método\n            </a>\n            <a class=\"hover:text-[var(--clay)] transition-colors\" data-kid=\"2-2-2-3\" data-name=\"navigation link faq\" href=\"#faq\">\n                Dúvidas\n            </a>\n        </div>\n        <a class=\"font-mono text-[11px] border border-dashed border-[var(--bark)]/30 px-6 py-2 uppercase tracking-widest hover:bg-[var(--bark)]/5\" data-kid=\"2-2-3\" data-name=\"call-to-action schedule button\" href=\"#pricing\">\n            Agendar\n        </a>\n    </nav>\n    \n    <section class=\"relative min-h-[90vh] flex flex-col\" data-kid=\"2-3\" data-name=\"hero section\">\n        <div class=\"grid lg:grid-cols-2 flex-grow\" data-kid=\"2-3-1\" data-name=\"hero content grid\">\n            \n            <div class=\"absolute left-1/2 top-0 bottom-0 dashed-stitch hidden lg:block -translate-x-1/2 z-20\" data-kid=\"2-3-1-1\" data-name=\"vertical separator line\">\n            </div>\n            <div class=\"flex flex-col justify-center px-8 md:px-24 py-20 relative z-10\" data-kid=\"2-3-1-2\" data-name=\"hero text content area\" data-scroll=\"\" data-scroll-speed=\"0.1\">\n                <div class=\"font-mono text-[11px] tracking-[0.4em] uppercase text-[var(--bark)]/50 mb-12 flex items-center gap-4\" data-kid=\"2-3-1-2-1\" data-name=\"hero breadcrumb container\">\n                    <span class=\"w-12 h-[1.5px] bg-[var(--bark)]/20\" data-kid=\"2-3-1-2-1-1\" data-name=\"breadcrumb separator line\">\n                    </span>\n                    Clinical Ledger\n                </div>\n                <div class=\"max-w-xl\" data-kid=\"2-3-1-2-2\" data-name=\"hero headline group\">\n                    <p class=\"font-mono text-[11px] tracking-[0.3em] uppercase text-[var(--clay)] mb-6\" data-kid=\"2-3-1-2-2-1\" data-name=\"hero small title text\">\n                        Vol. 01 — Psychoanalysis\n                    </p>\n                    <h1 class=\"font-display text-[clamp(3.5rem,8vw,6.5rem)] leading-[0.92] font-500 mb-10\" data-kid=\"2-3-1-2-2-2\" data-name=\"hero main headline\">\n                        Descubra o\n                        <span class=\"italic font-400\" data-kid=\"2-3-1-2-2-2-1\" data-name=\"italicized headline word\">\n                            poder\n                        </span>\n                        da psicanálise\n                    </h1>\n                    <p class=\"text-[17px] text-[var(--bark)]/80 leading-relaxed max-w-md mb-12\" data-kid=\"2-3-1-2-2-3\" data-name=\"hero description text\">\n                        Aprofunde-se em suas emoções e relacionamentos através da compreensão psicanalítica. Uma escuta clínica e profundamente humana.\n                    </p>\n                    <div class=\"flex flex-wrap gap-6\" data-kid=\"2-3-1-2-2-4\" data-name=\"hero button group\">\n                        <a class=\"btn-clay\" data-kid=\"2-3-1-2-2-4-1\" data-name=\"hero primary action button\" href=\"#pricing\">\n                            Iniciar Jornada\n                        </a>\n                        <a class=\"font-mono text-xs tracking-[0.2em] uppercase border-b border-dashed border-[var(--bark)]/40 pb-1 hover:text-[var(--clay)] transition-colors\" data-kid=\"2-3-1-2-2-4-2\" data-name=\"hero secondary action link\" href=\"#journey\">\n                            Explorar Método\n                        </a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"relative overflow-hidden bg-[var(--moss)]/10 min-h-[500px]\" data-kid=\"2-3-1-3\" data-name=\"hero image and decorative area\">\n                <img alt=\"Consultation Space\" class=\"absolute inset-0 w-full h-full object-cover grayscale-[20%] sepia-[5%] opacity-90\" data-kid=\"2-3-1-3-1\" data-name=\"hero background image\" src=\"https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&w=1200&q=80&fit=crop\">\n                <div class=\"absolute inset-0 bg-[var(--bark)]/10\" data-kid=\"2-3-1-3-2\" data-name=\"hero color overlay\">\n                </div>\n                <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"2-3-1-3-3\" data-name=\"hero wax seal container\">\n                    <div class=\"wax-seal\" data-kid=\"2-3-1-3-3-1\" data-name=\"animated wax seal icon\">\n                    </div>\n                </div>\n                <div class=\"absolute bottom-10 right-10 font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--linen)] bg-[var(--bark)]/40 px-4 py-2 backdrop-blur-sm\" data-kid=\"2-3-1-3-4\" data-name=\"hero image caption tag\">\n                    Plate I — The Analytic Space\n                </div>\n            </div>\n        </div>\n        <div class=\"font-mono text-[10px] tracking-[0.3em] uppercase text-[var(--bark)]/40 flex justify-between px-16 py-6 border-t border-dashed border-[var(--bark)]/10\" data-kid=\"2-3-2\" data-name=\"hero footer bar\">\n            <span data-kid=\"2-3-2-1\" data-name=\"establishment date text\">\n                Est. MMXXIV\n            </span>\n            <span data-kid=\"2-3-2-2\" data-name=\"session identifier text\">\n                Documented Session 001\n            </span>\n        </div>\n    </section>\n    <div class=\"stitch-row opacity-30\" data-kid=\"2-4\" data-name=\"decorative horizontal stitch line\">\n    </div>\n    \n    <section class=\"relative py-32 md:py-48 px-8 bg-[var(--moss)] text-[var(--linen)]\" data-kid=\"2-5\" data-name=\"specialties section\" id=\"specialties\">\n        <div class=\"grain\" data-kid=\"2-5-1\" data-name=\"section texture grain overlay\">\n        </div>\n        <div class=\"max-w-6xl mx-auto relative z-10\" data-kid=\"2-5-2\" data-name=\"specialties content container\">\n            <div class=\"text-center mb-24\" data-kid=\"2-5-2-1\" data-name=\"specialties header container\">\n                <p class=\"font-mono text-xs tracking-[0.4em] uppercase opacity-60 mb-4\" data-kid=\"2-5-2-1-1\" data-name=\"specialties subheadline text\">\n                    Especialidades Clínicas\n                </p>\n                <h2 class=\"font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-tight\" data-kid=\"2-5-2-1-2\" data-name=\"specialties main title text\">\n                    Áreas de Atendimento\n                </h2>\n                <p class=\"font-mono text-[11px] mt-6 opacity-50 italic tracking-[0.2em]\" data-kid=\"2-5-2-1-3\" data-name=\"specialties instructional text\">\n                    Arraste os registros para organizar seu pensamento\n                </p>\n            </div>\n            <div class=\"relative w-full h-[550px] md:h-[650px]\" data-kid=\"2-5-2-2\" data-name=\"draggable polaroid board\" id=\"board\">\n                \n                <div class=\"polaroid chip absolute w-64 md:w-72\" data-kid=\"2-5-2-2-1\" data-name=\"polaroid card depression\" style=\"left: 5%; top: 15%; transform: rotate(-4deg);\">\n                    <img alt=\"Depression\" class=\"w-full aspect-square object-cover mb-4 grayscale-[50%] sepia-[10%]\" data-kid=\"2-5-2-2-1-1\" data-name=\"polaroid image depression\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1516534775068-ba3e84529ec1?auto=format&w=600&q=80&fit=crop\">\n                    <p class=\"font-mono text-[10px] tracking-[0.3em] uppercase text-[var(--clay)] mb-2\" data-kid=\"2-5-2-2-1-2\" data-name=\"polaroid reference number text\">\n                        Ref. 01\n                    </p>\n                    <h3 class=\"font-display text-2xl text-[var(--bark)]\" data-kid=\"2-5-2-2-1-3\" data-name=\"polaroid title text\">\n                        Depressão\n                    </h3>\n                    <p class=\"text-[13px] text-[var(--bark)]/70 mt-3 leading-relaxed\" data-kid=\"2-5-2-2-1-4\" data-name=\"polaroid description text\">\n                        A psicanálise desvenda as raízes da tristeza, promovendo um entendimento profundo.\n                    </p>\n                </div>\n                \n                <div class=\"polaroid chip absolute w-64 md:w-72\" data-kid=\"2-5-2-2-2\" data-name=\"polaroid card relationships\" style=\"left: 35%; top: 40%; transform: rotate(3deg);\">\n                    <img alt=\"Relationships\" class=\"w-full aspect-square object-cover mb-4 grayscale-[50%] sepia-[10%]\" data-kid=\"2-5-2-2-2-1\" data-name=\"polaroid image relationships\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1518199266791-5375a83190b7?auto=format&w=600&q=80&fit=crop\">\n                    <p class=\"font-mono text-[10px] tracking-[0.3em] uppercase text-[var(--clay)] mb-2\" data-kid=\"2-5-2-2-2-2\" data-name=\"polaroid reference number text\">\n                        Ref. 02\n                    </p>\n                    <h3 class=\"font-display text-2xl text-[var(--bark)]\" data-kid=\"2-5-2-2-2-3\" data-name=\"polaroid title text\">\n                        Relacionamentos\n                    </h3>\n                    <p class=\"text-[13px] text-[var(--bark)]/70 mt-3 leading-relaxed\" data-kid=\"2-5-2-2-2-4\" data-name=\"polaroid description text\">\n                        Explore os laços afetivos e as dinâmicas que moldam suas conexões interpessoais.\n                    </p>\n                </div>\n                \n                <div class=\"polaroid chip absolute w-64 md:w-72\" data-kid=\"2-5-2-2-3\" data-name=\"polaroid card adhd\" style=\"left: 65%; top: 25%; transform: rotate(-2deg);\">\n                    <img alt=\"ADHD\" class=\"w-full aspect-square object-cover mb-4 grayscale-[50%] sepia-[10%]\" data-kid=\"2-5-2-2-3-1\" data-name=\"polaroid image adhd\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?auto=format&w=600&q=80&fit=crop\">\n                    <p class=\"font-mono text-[10px] tracking-[0.3em] uppercase text-[var(--clay)] mb-2\" data-kid=\"2-5-2-2-3-2\" data-name=\"polaroid reference number text\">\n                        Ref. 03\n                    </p>\n                    <h3 class=\"font-display text-2xl text-[var(--bark)]\" data-kid=\"2-5-2-2-3-3\" data-name=\"polaroid title text\">\n                        TDAH\n                    </h3>\n                    <p class=\"text-[13px] text-[var(--bark)]/70 mt-3 leading-relaxed\" data-kid=\"2-5-2-2-3-4\" data-name=\"polaroid description text\">\n                        A psicanálise ajuda a entender como as experiências influenciam o comportamento.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </section>\n    <div class=\"stitch-row opacity-30\" data-kid=\"2-6\" data-name=\"decorative horizontal stitch line\">\n    </div>\n    \n    <section class=\"py-32 px-8 text-center bg-[var(--linen)]\" data-kid=\"2-7\" data-name=\"quote section\">\n        <div class=\"max-w-3xl mx-auto\" data-kid=\"2-7-1\" data-name=\"quote content container\">\n            <p class=\"font-mono text-xs tracking-[0.4em] uppercase text-[var(--clay)] mb-8\" data-kid=\"2-7-1-1\" data-name=\"quote subheadline text\">\n                Filosofia Clínica\n            </p>\n            <h2 class=\"font-display text-[clamp(2rem,5vw,3.5rem)] italic leading-tight text-[var(--bark)]\" data-kid=\"2-7-1-2\" data-name=\"quote text\">\n                \"Uma escuta clínica e profundamente humana, onde o silêncio também fala.\"\n            </h2>\n            <div class=\"mt-12 flex items-center justify-center gap-4\" data-kid=\"2-7-1-3\" data-name=\"quote separator line group\">\n                <span class=\"w-12 h-[1px] bg-[var(--bark)]/20\" data-kid=\"2-7-1-3-1\" data-name=\"quote separator line left\">\n                </span>\n                <span class=\"font-mono text-[11px] tracking-[0.2em] uppercase opacity-60\" data-kid=\"2-7-1-3-2\" data-name=\"quote attribution text\">\n                    Psychoanalysis Archive\n                </span>\n                <span class=\"w-12 h-[1px] bg-[var(--bark)]/20\" data-kid=\"2-7-1-3-3\" data-name=\"quote separator line right\">\n                </span>\n            </div>\n        </div>\n    </section>\n    <div class=\"stitch-row opacity-30\" data-kid=\"2-8\" data-name=\"decorative horizontal stitch line\">\n    </div>\n    \n    <section class=\"relative py-32 md:py-48 px-8 overflow-hidden\" data-kid=\"2-9\" data-name=\"journey section\" id=\"journey\">\n        <div class=\"max-w-5xl mx-auto relative\" data-kid=\"2-9-1\" data-name=\"journey content container\">\n            <div class=\"text-center mb-32\" data-kid=\"2-9-1-1\" data-name=\"journey header container\">\n                <p class=\"font-mono text-xs tracking-[0.4em] uppercase text-[var(--clay)] mb-4\" data-kid=\"2-9-1-1-1\" data-name=\"journey subheadline text\">\n                    A Jornada Analítica\n                </p>\n                <h2 class=\"font-display text-[clamp(2.5rem,6vw,4rem)]\" data-kid=\"2-9-1-1-2\" data-name=\"journey main title text\">\n                    Por que este atendimento?\n                </h2>\n                <p class=\"font-body text-[16px] text-[var(--bark)]/70 mt-6 max-w-xl mx-auto\" data-kid=\"2-9-1-1-3\" data-name=\"journey description text\">\n                    Mapeamos os pilares que sustentam nossa prática clínica, garantindo um espaço de transformação e segurança.\n                </p>\n            </div>\n            <div class=\"relative\" data-kid=\"2-9-1-2\" data-name=\"journey timeline container\">\n                \n                <svg class=\"absolute left-1/2 -translate-x-1/2 top-0 h-full w-[120px] hidden md:block opacity-40\" data-dynamic=\"true\" data-kid=\"2-9-1-2-1\" data-name=\"vine timeline svg path\" data-reason=\"path visual length is animated based on scroll position\" id=\"vine-svg\" preserveaspectratio=\"none\" viewbox=\"0 0 120 1600\">\n                    <path d=\"M60,0 C80,200 40,400 60,600 C80,800 40,1000 60,1200 C80,1400 40,1600 60,1800\" fill=\"none\" id=\"vine-path\" stroke=\"var(--bark)\" stroke-dasharray=\"10 10\" stroke-width=\"3\" data-kid=\"3\">\n                    </path>\n                </svg>\n                <div class=\"space-y-24 md:space-y-32 relative z-10\" data-kid=\"2-9-1-2-2\" data-name=\"journey timeline steps group\">\n                    \n                    <div class=\"reveal grid md:grid-cols-2 items-center gap-12 md:gap-24\" data-kid=\"2-9-1-2-2-1\" data-name=\"timeline step 1 container\">\n                        <div class=\"md:text-right order-2 md:order-1\" data-kid=\"2-9-1-2-2-1-1\" data-name=\"timeline step 1 text content\">\n                            <p class=\"font-mono text-[12px] tracking-[0.3em] uppercase text-[var(--clay)] mb-4\" data-kid=\"2-9-1-2-2-1-1-1\" data-name=\"timeline step 1 label\">\n                                01. Conforto\n                            </p>\n                            <h3 class=\"font-display text-4xl mb-6 leading-tight\" data-kid=\"2-9-1-2-2-1-1-2\" data-name=\"timeline step 1 title\">\n                                Ambiente Seguro\n                            </h3>\n                            <p class=\"text-[17px] text-[var(--bark)]/70 leading-relaxed md:ml-auto md:max-w-md\" data-kid=\"2-9-1-2-2-1-1-3\" data-name=\"timeline step 1 description\">\n                                Sessões no local onde você se sente mais seguro e acolhido, facilitando a abertura emocional necessária para o processo.\n                            </p>\n                        </div>\n                        <div class=\"order-1 md:order-2\" data-kid=\"2-9-1-2-2-1-2\" data-name=\"timeline step 1 image\">\n                            <img alt=\"Comfort\" class=\"w-full aspect-[4/3] object-cover grayscale-[50%] sepia-[10%] shadow-xl\" data-kid=\"2-9-1-2-2-1-2-1\" data-name=\"timeline step 1 image element\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1520004434532-668416a08753?auto=format&w=800&q=80&fit=crop\">\n                        </div>\n                    </div>\n                    \n                    <div class=\"reveal grid md:grid-cols-2 items-center gap-12 md:gap-24\" data-kid=\"2-9-1-2-2-2\" data-name=\"timeline step 2 container\">\n                        <div class=\"order-1\" data-kid=\"2-9-1-2-2-2-1\" data-name=\"timeline step 2 image\">\n                            <img alt=\"Accessibility\" class=\"w-full aspect-[4/3] object-cover grayscale-[50%] sepia-[10%] shadow-xl\" data-kid=\"2-9-1-2-2-2-1-1\" data-name=\"timeline step 2 image element\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1499750310107-5fef28a66643?auto=format&w=800&q=80&fit=crop\">\n                        </div>\n                        <div class=\"order-2\" data-kid=\"2-9-1-2-2-2-2\" data-name=\"timeline step 2 text content\">\n                            <p class=\"font-mono text-[12px] tracking-[0.3em] uppercase text-[var(--clay)] mb-4\" data-kid=\"2-9-1-2-2-2-2-1\" data-name=\"timeline step 2 label\">\n                                02. Acessibilidade\n                            </p>\n                            <h3 class=\"font-display text-4xl mb-6 leading-tight\" data-kid=\"2-9-1-2-2-2-2-2\" data-name=\"timeline step 2 title\">\n                                Onde você estiver\n                            </h3>\n                            <p class=\"text-[17px] text-[var(--bark)]/70 leading-relaxed md:max-w-md\" data-kid=\"2-9-1-2-2-2-2-3\" data-name=\"timeline step 2 description\">\n                                Atendimento flexível por videochamada, rompendo barreiras geográficas e otimizando seu tempo diário.\n                            </p>\n                        </div>\n                    </div>\n                    \n                    <div class=\"reveal grid md:grid-cols-2 items-center gap-12 md:gap-24\" data-kid=\"2-9-1-2-2-3\" data-name=\"timeline step 3 container\">\n                        <div class=\"md:text-right order-2 md:order-1\" data-kid=\"2-9-1-2-2-3-1\" data-name=\"timeline step 3 text content\">\n                            <p class=\"font-mono text-[12px] tracking-[0.3em] uppercase text-[var(--clay)] mb-4\" data-kid=\"2-9-1-2-2-3-1-1\" data-name=\"timeline step 3 label\">\n                                03. Economia\n                            </p>\n                            <h3 class=\"font-display text-4xl mb-6 leading-tight\" data-kid=\"2-9-1-2-2-3-1-2\" data-name=\"timeline step 3 title\">\n                                Foco no Essencial\n                            </h3>\n                            <p class=\"text-[17px] text-[var(--bark)]/70 leading-relaxed md:ml-auto md:max-w-md\" data-kid=\"2-9-1-2-2-3-1-3\" data-name=\"timeline step 3 description\">\n                                Sem deslocamento, sem trânsito. O foco total permanece inteiramente no seu processo profundo de autodescoberta.\n                            </p>\n                        </div>\n                        <div class=\"order-1 md:order-2\" data-kid=\"2-9-1-2-2-3-2\" data-name=\"timeline step 3 image\">\n                            <img alt=\"Economy\" class=\"w-full aspect-[4/3] object-cover grayscale-[50%] sepia-[10%] shadow-xl\" data-kid=\"2-9-1-2-2-3-2-1\" data-name=\"timeline step 3 image element\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85?auto=format&w=800&q=80&fit=crop\">\n                        </div>\n                    </div>\n                    \n                    <div class=\"reveal grid md:grid-cols-2 items-center gap-12 md:gap-24\" data-kid=\"2-9-1-2-2-4\" data-name=\"timeline step 4 container\">\n                        <div class=\"order-1\" data-kid=\"2-9-1-2-2-4-1\" data-name=\"timeline step 4 image\">\n                            <img alt=\"Privacy\" class=\"w-full aspect-[4/3] object-cover grayscale-[50%] sepia-[10%] shadow-xl\" data-kid=\"2-9-1-2-2-4-1-1\" data-name=\"timeline step 4 image element\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&w=800&q=80&fit=crop\">\n                        </div>\n                        <div class=\"order-2\" data-kid=\"2-9-1-2-2-4-2\" data-name=\"timeline step 4 text content\">\n                            <p class=\"font-mono text-[12px] tracking-[0.3em] uppercase text-[var(--clay)] mb-4\" data-kid=\"2-9-1-2-2-4-2-1\" data-name=\"timeline step 4 label\">\n                                04. Privacidade\n                            </p>\n                            <h3 class=\"font-display text-4xl mb-6 leading-tight\" data-kid=\"2-9-1-2-2-4-2-2\" data-name=\"timeline step 4 title\">\n                                Sigilo Absoluto\n                            </h3>\n                            <p class=\"text-[17px] text-[var(--bark)]/70 leading-relaxed md:max-w-md\" data-kid=\"2-9-1-2-2-4-2-3\" data-name=\"timeline step 4 description\">\n                                Plataforma de vídeo segura e criptografada, respeitando integralmente os mais altos padrões de ética clínica.\n                            </p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <div class=\"stitch-row opacity-30\" data-kid=\"2-10\" data-name=\"decorative horizontal stitch line\">\n    </div>\n    \n    <section class=\"py-32 md:py-48 px-8\" data-kid=\"2-11\" data-name=\"faq section\" id=\"faq\">\n        <div class=\"max-w-6xl mx-auto\" data-kid=\"2-11-1\" data-name=\"faq content container\">\n            <div class=\"grid lg:grid-cols-2 gap-24 items-start\" data-kid=\"2-11-1-1\" data-name=\"faq and pricing grid\">\n                \n                <div data-kid=\"2-11-1-1-1\" data-name=\"faq container\" data-scroll=\"\" data-scroll-speed=\"0.2\">\n                    <p class=\"font-mono text-xs tracking-[0.4em] uppercase text-[var(--clay)] mb-8\" data-kid=\"2-11-1-1-1-1\" data-name=\"faq subheadline text\">\n                        Dúvidas Frequentes\n                    </p>\n                    <h2 class=\"font-display text-5xl mb-16 leading-tight\" data-kid=\"2-11-1-1-1-2\" data-name=\"faq main title text\">\n                        Esclarecendo o Processo\n                    </h2>\n                    <div class=\"space-y-4\" data-kid=\"2-11-1-1-1-3\" data-name=\"faq accordion list\">\n                        <details class=\"group ledger-item\" data-kid=\"2-11-1-1-1-3-1\" data-name=\"accordion item 1\" open=\"\">\n                            <summary class=\"flex justify-between items-center cursor-pointer list-none\" data-kid=\"2-11-1-1-1-3-1-1\" data-name=\"accordion title 1 container\">\n                                <span class=\"font-display text-2xl group-hover:text-[var(--clay)] transition-colors\" data-kid=\"2-11-1-1-1-3-1-1-1\" data-name=\"accordion question text 1\">\n                                    Como funciona o atendimento?\n                                </span>\n                                <span class=\"font-mono text-2xl group-open:rotate-45 transition-transform duration-300\" data-kid=\"2-11-1-1-1-3-1-1-2\" data-name=\"accordion toggle symbol 1\">\n                                    +\n                                </span>\n                            </summary>\n                            <div class=\"details-content\" data-kid=\"2-11-1-1-1-3-1-2\" data-name=\"accordion content 1\">\n                                <div class=\"details-inner\" data-kid=\"2-11-1-1-1-3-1-2-1\" data-name=\"accordion inner wrapper 1\">\n                                    <div class=\"pt-6 text-[17px] text-[var(--bark)]/70 leading-relaxed font-body\" data-kid=\"2-11-1-1-1-3-1-2-1-1\" data-name=\"accordion answer text 1\">\n                                        Sessões semanais de 50 minutos, realizadas por videochamada. O link é enviado previamente para seu acesso seguro.\n                                    </div>\n                                </div>\n                            </div>\n                        </details>\n                        <details class=\"group ledger-item\" data-kid=\"2-11-1-1-1-3-2\" data-name=\"accordion item 2\">\n                            <summary class=\"flex justify-between items-center cursor-pointer list-none\" data-kid=\"2-11-1-1-1-3-2-1\" data-name=\"accordion title 2 container\">\n                                <span class=\"font-display text-2xl group-hover:text-[var(--clay)] transition-colors\" data-kid=\"2-11-1-1-1-3-2-1-1\" data-name=\"accordion question text 2\">\n                                    Aceita convênio médico?\n                                </span>\n                                <span class=\"font-mono text-2xl group-open:rotate-45 transition-transform duration-300\" data-kid=\"2-11-1-1-1-3-2-1-2\" data-name=\"accordion toggle symbol 2\">\n                                    +\n                                </span>\n                            </summary>\n                            <div class=\"details-content\" data-kid=\"2-11-1-1-1-3-2-2\" data-name=\"accordion content 2\">\n                                <div class=\"details-inner\" data-kid=\"2-11-1-1-1-3-2-2-1\" data-name=\"accordion inner wrapper 2\">\n                                    <div class=\"pt-6 text-[17px] text-[var(--bark)]/70 leading-relaxed font-body\" data-kid=\"2-11-1-1-1-3-2-2-1-1\" data-name=\"accordion answer text 2\">\n                                        Atuamos apenas com modalidade particular. Fornecemos recibos para que você possa solicitar reembolso junto ao seu plano de saúde.\n                                    </div>\n                                </div>\n                            </div>\n                        </details>\n                        <details class=\"group ledger-item\" data-kid=\"2-11-1-1-1-3-3\" data-name=\"accordion item 3\">\n                            <summary class=\"flex justify-between items-center cursor-pointer list-none\" data-kid=\"2-11-1-1-1-3-3-1\" data-name=\"accordion title 3 container\">\n                                <span class=\"font-display text-2xl group-hover:text-[var(--clay)] transition-colors\" data-kid=\"2-11-1-1-1-3-3-1-1\" data-name=\"accordion question text 3\">\n                                    Atende online para todo o Brasil?\n                                </span>\n                                <span class=\"font-mono text-2xl group-open:rotate-45 transition-transform duration-300\" data-kid=\"2-11-1-1-1-3-3-1-2\" data-name=\"accordion toggle symbol 3\">\n                                    +\n                                </span>\n                            </summary>\n                            <div class=\"details-content\" data-kid=\"2-11-1-1-1-3-3-2\" data-name=\"accordion content 3\">\n                                <div class=\"details-inner\" data-kid=\"2-11-1-1-1-3-3-2-1\" data-name=\"accordion inner wrapper 3\">\n                                    <div class=\"pt-6 text-[17px] text-[var(--bark)]/70 leading-relaxed font-body\" data-kid=\"2-11-1-1-1-3-3-2-1-1\" data-name=\"accordion answer text 3\">\n                                        Sim, atendemos pacientes em todo o território nacional e também brasileiros residentes no exterior.\n                                    </div>\n                                </div>\n                            </div>\n                        </details>\n                        <details class=\"group ledger-item\" data-kid=\"2-11-1-1-1-3-4\" data-name=\"accordion item 4\">\n                            <summary class=\"flex justify-between items-center cursor-pointer list-none\" data-kid=\"2-11-1-1-1-3-4-1\" data-name=\"accordion title 4 container\">\n                                <span class=\"font-display text-2xl group-hover:text-[var(--clay)] transition-colors\" data-kid=\"2-11-1-1-1-3-4-1-1\" data-name=\"accordion question text 4\">\n                                    Menores de idade podem agendar?\n                                </span>\n                                <span class=\"font-mono text-2xl group-open:rotate-45 transition-transform duration-300\" data-kid=\"2-11-1-1-1-3-4-1-2\" data-name=\"accordion toggle symbol 4\">\n                                    +\n                                </span>\n                            </summary>\n                            <div class=\"details-content\" data-kid=\"2-11-1-1-1-3-4-2\" data-name=\"accordion content 4\">\n                                <div class=\"details-inner\" data-kid=\"2-11-1-1-1-3-4-2-1\" data-name=\"accordion inner wrapper 4\">\n                                    <div class=\"pt-6 text-[17px] text-[var(--bark)]/70 leading-relaxed font-body\" data-kid=\"2-11-1-1-1-3-4-2-1-1\" data-name=\"accordion answer text 4\">\n                                        Sim, mediante autorização expressa dos responsáveis legais e triagem inicial específica.\n                                    </div>\n                                </div>\n                            </div>\n                        </details>\n                    </div>\n                </div>\n                \n                <div class=\"lg:sticky lg:top-32 bg-[var(--moss)]/5 border-2 border-dashed border-[var(--bark)]/10 p-12 md:p-16 relative\" data-kid=\"2-11-1-1-2\" data-name=\"pricing card container\" id=\"pricing\">\n                    <p class=\"font-mono text-[11px] tracking-[0.3em] uppercase text-[var(--clay)] mb-6\" data-kid=\"2-11-1-1-2-1\" data-name=\"pricing subheadline text\">\n                        Investimento Clínico\n                    </p>\n                    <h3 class=\"font-display text-4xl mb-4\" data-kid=\"2-11-1-1-2-2\" data-name=\"pricing title text\">\n                        Sessão Individual\n                    </h3>\n                    <p class=\"font-body text-[15px] text-[var(--bark)]/60 mb-12 italic leading-relaxed\" data-kid=\"2-11-1-1-2-3\" data-name=\"pricing description text\">\n                        Valor referente a cada encontro semanal. Documentado e referenciado pelas diretrizes do CRP.\n                    </p>\n                    <div class=\"flex items-baseline gap-3 mb-16\" data-kid=\"2-11-1-1-2-4\" data-name=\"price amount container\">\n                        <span class=\"font-mono text-2xl text-[var(--clay)]\" data-kid=\"2-11-1-1-2-4-1\" data-name=\"currency symbol text\">\n                            R$\n                        </span>\n                        <span class=\"font-display text-8xl text-[var(--bark)]\" data-kid=\"2-11-1-1-2-4-2\" data-name=\"price value text\">\n                            250\n                        </span>\n                        <span class=\"font-mono text-sm opacity-50 tracking-wider\" data-kid=\"2-11-1-1-2-4-3\" data-name=\"pricing frequency text\">\n                            / sessão\n                        </span>\n                    </div>\n                    <a class=\"block w-full btn-clay text-center py-6 text-sm mb-6 shadow-lg shadow-[var(--clay)]/20\" data-kid=\"2-11-1-1-2-5\" data-name=\"pricing action button\" href=\"#\">\n                        Agendar Primeira Consulta\n                    </a>\n                    <div class=\"mt-12 pt-12 border-t border-dashed border-[var(--bark)]/10 text-center\" data-kid=\"2-11-1-1-2-6\" data-name=\"whatsapp contact container\">\n                        <p class=\"font-mono text-[10px] tracking-[0.2em] uppercase opacity-60 mb-8\" data-kid=\"2-11-1-1-2-6-1\" data-name=\"whatsapp contact label\">\n                            Conversa Imediata\n                        </p>\n                        <a class=\"inline-flex items-center gap-4 group\" data-kid=\"2-11-1-1-2-6-2\" data-name=\"whatsapp contact button\" href=\"https://wa.me/...\">\n                            <span class=\"p-4 rounded-full bg-emerald-600/10 text-emerald-700 group-hover:scale-110 transition-transform\" data-kid=\"2-11-1-1-2-6-2-1\" data-name=\"whatsapp icon container\">\n                                <svg class=\"lucide lucide-message-circle\" data-kid=\"2-11-1-1-2-6-2-1-1\" data-name=\"whatsapp message icon\" fill=\"none\" height=\"24\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n                                    <path d=\"M7.9 20A9 9 0 1 0 4 16.1L2 22Z\" data-kid=\"4\">\n                                    </path>\n                                    <path d=\"M8 12h.01\" data-kid=\"5\">\n                                    </path>\n                                    <path d=\"M12 12h.01\" data-kid=\"6\">\n                                    </path>\n                                    <path d=\"M16 12h.01\" data-kid=\"7\">\n                                    </path>\n                                </svg>\n                            </span>\n                            <span class=\"font-mono text-xs tracking-[0.3em] uppercase text-[var(--bark)] group-hover:text-[var(--clay)] transition-colors\" data-kid=\"2-11-1-1-2-6-2-2\" data-name=\"whatsapp button text\">\n                                Falar no WhatsApp\n                            </span>\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <section class=\"py-24 px-8\" data-kid=\"2-12\" data-name=\"cta banner section\">\n        <div class=\"max-w-5xl mx-auto bg-[var(--bark)] text-[var(--linen)] p-12 md:p-20 text-center relative overflow-hidden border border-dashed border-[var(--linen)]/20\" data-kid=\"2-12-1\" data-name=\"cta banner inner container\">\n            <div class=\"grain opacity-10\" data-kid=\"2-12-1-1\" data-name=\"cta banner texture grain\">\n            </div>\n            <div class=\"relative z-10\" data-kid=\"2-12-1-2\" data-name=\"cta banner content area\">\n                <p class=\"font-mono text-xs tracking-[0.5em] uppercase opacity-60 mb-8\" data-kid=\"2-12-1-2-1\" data-name=\"cta banner subheadline\">\n                    O Primeiro Passo\n                </p>\n                <h2 class=\"font-display text-[clamp(2rem,5vw,3.5rem)] mb-12\" data-kid=\"2-12-1-2-2\" data-name=\"cta banner headline\">\n                    Vamos iniciar sua jornada de autodescoberta?\n                </h2>\n                <a class=\"inline-block btn-clay bg-[var(--linen)] text-[var(--bark)] border-none\" data-kid=\"2-12-1-2-3\" data-name=\"cta banner button\" href=\"#\">\n                    Agendar Agora\n                </a>\n            </div>\n        </div>\n    </section>\n    \n    <footer class=\"py-20 px-8 border-t border-dashed border-[var(--bark)]/10\" data-kid=\"2-13\" data-name=\"footer\">\n        <div class=\"max-w-6xl mx-auto grid md:grid-cols-3 gap-16 items-start\" data-kid=\"2-13-1\" data-name=\"footer grid container\">\n            <div class=\"max-w-xs\" data-kid=\"2-13-1-1\" data-name=\"footer bio container\">\n                <h3 class=\"font-display text-3xl font-600 mb-6 italic\" data-kid=\"2-13-1-1-1\" data-name=\"footer logo title\">\n                    Elena Silva\n                </h3>\n                <p class=\"text-[14px] text-[var(--bark)]/60 leading-relaxed\" data-kid=\"2-13-1-1-2\" data-name=\"footer bio text\">\n                    Psicólogo clínico dedicado ao estudo e prática da psicanálise. CRP 07/324423. Atendimento humanizado e ético.\n                </p>\n            </div>\n            <div class=\"space-y-4\" data-kid=\"2-13-1-2\" data-name=\"footer navigation container\">\n                <p class=\"font-mono text-[10px] tracking-[0.3em] uppercase text-[var(--clay)] mb-6\" data-kid=\"2-13-1-2-1\" data-name=\"footer navigation title\">\n                    Navegação\n                </p>\n                <div class=\"flex flex-col gap-3 font-mono text-[11px] tracking-widest opacity-70\" data-kid=\"2-13-1-2-2\" data-name=\"footer navigation links\">\n                    <a class=\"hover:text-[var(--clay)] transition-colors\" data-kid=\"2-13-1-2-2-1\" data-name=\"footer link home\" href=\"#\">\n                        Início\n                    </a>\n                    <a class=\"hover:text-[var(--clay)] transition-colors\" data-kid=\"2-13-1-2-2-2\" data-name=\"footer link specialties\" href=\"#specialties\">\n                        Especialidades\n                    </a>\n                    <a class=\"hover:text-[var(--clay)] transition-colors\" data-kid=\"2-13-1-2-2-3\" data-name=\"footer link journey\" href=\"#journey\">\n                        A Jornada\n                    </a>\n                    <a class=\"hover:text-[var(--clay)] transition-colors\" data-kid=\"2-13-1-2-2-4\" data-name=\"footer link consultas\" href=\"#faq\">\n                        Consultas\n                    </a>\n                </div>\n            </div>\n            <div data-kid=\"2-13-1-3\" data-name=\"footer location container\">\n                <p class=\"font-mono text-[10px] tracking-[0.3em] uppercase text-[var(--clay)] mb-6\" data-kid=\"2-13-1-3-1\" data-name=\"footer location title\">\n                    Localização\n                </p>\n                <div class=\"flex items-center gap-2 font-mono text-[11px] opacity-70\" data-kid=\"2-13-1-3-2\" data-name=\"footer location address\">\n                    <svg class=\"lucide lucide-map-pin\" data-kid=\"2-13-1-3-2-1\" data-name=\"map pin icon\" fill=\"none\" height=\"14\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"14\" xmlns=\"http://www.w3.org/2000/svg\">\n                        <path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\" data-kid=\"8\">\n                        </path>\n                        <circle cx=\"12\" cy=\"10\" r=\"3\" data-kid=\"9\">\n                        </circle>\n                    </svg>\n                    São Leopoldo, RS — Brasil\n                </div>\n                <p class=\"mt-8 font-mono text-[11px] opacity-50 uppercase tracking-widest\" data-kid=\"2-13-1-3-3\" data-name=\"footer copyright text\">\n                    © MMXXIV Clinical Ledger — Vol. 01\n                </p>\n            </div>\n        </div>\n    </footer>\n</div>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"10\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"11\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/Draggable.min.js\" data-kid=\"12\"></script>\n<script data-kid=\"13\">\n    gsap.registerPlugin(ScrollTrigger, Draggable);\n</script>\n<script type=\"module\" data-kid=\"14\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n\n  // Initialize Lenis\n  const lenis = new Lenis();\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Draggable Polaroids\n  Draggable.create(\".chip\", {\n    bounds: \"#board\",\n    inertia: true\n  });\n\n  // Reveal animations\n  gsap.utils.toArray('.reveal').forEach((el) => {\n    gsap.from(el, {\n      opacity: 0,\n      y: 100,\n      duration: 1.2,\n      ease: 'power3.out',\n      scrollTrigger: {\n        trigger: el,\n        start: 'top 85%'\n      }\n    });\n  });\n\n  // Vine Path Animation\n  const vinePath = document.getElementById('vine-path');\n  if (vinePath) {\n    const pathLength = vinePath.getTotalLength();\n    gsap.set(vinePath, { strokeDasharray: pathLength, strokeDashoffset: pathLength });\n    gsap.to(vinePath, {\n      strokeDashoffset: 0,\n      ease: 'none',\n      scrollTrigger: {\n        trigger: '#journey',\n        start: 'top 30%',\n        end: 'bottom bottom',\n        scrub: 1\n      }\n    });\n  }\n\n  // Wax Seal Ambient Movement\n  gsap.to('.wax-seal', {\n    rotate: 15,\n    duration: 3,\n    repeat: -1,\n    yoyo: true,\n    ease: 'sine.inOut'\n  });\n</script>\n",
      "comments": [],
      "created": "2026-07-16T02:52:24.306709+00:00",
