        "head": "<meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>Olosirkon — Maasai Mara Safari Camp</title>\n    <script src=\"https://unpkg.com/@tailwindcss/browser@4\"></script>"
